---
import Layout from '../layouts/Layout.astro';
import { Eye, EyeOff, Mail, Lock, User } from 'lucide-react';

const seo = {
  title: 'Üye Ol',
  description: 'Şanlıurfa.com\'a üye olun, mekan yorumlayın, puan verin ve Şanlıurfa\'yı keşfedin.',
  noindex: true,
};

const error = Astro.url.searchParams.get('error');
---

<Layout seo={seo}>
  <div class="min-h-screen bg-gray-50 dark:bg-gray-900 flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-md w-full space-y-8">
      <!-- Header -->
      <div class="text-center">
        <div class="mx-auto h-16 w-16 bg-urfa-600 rounded-2xl flex items-center justify-center">
          <span class="text-white font-bold text-2xl">Ş</span>
        </div>
        <h2 class="mt-6 text-3xl font-display font-bold text-gray-900 dark:text-white">
          Ücretsiz Üye Olun
        </h2>
        <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">
          Zaten hesabınız var mı?{' '}
          <a href="/giris" class="font-medium text-urfa-600 dark:text-urfa-400 hover:text-urfa-500">
            Giriş yapın
          </a>
        </p>
      </div>
      
      <!-- Error Message -->
      {error && (
        <div class="bg-red-50 border border-red-200 rounded-lg p-4">
          <p class="text-sm text-red-600">
            {error === 'email_exists' && 'Bu e-posta adresi zaten kullanımda.'}
            {error === 'weak_password' && 'Şifre en az 8 karakter olmalıdır.'}
            {error === 'invalid_email' && 'Geçerli bir e-posta adresi girin.'}
            {error === 'server_error' && 'Bir hata oluştu. Lütfen tekrar deneyin.'}
          </p>
        </div>
      )}
      
      <!-- Register Form -->
      <form class="mt-8 space-y-6" action="/api/auth/register" method="POST">
        <div class="space-y-4">
          <!-- Full Name -->
          <div>
            <label for="full-name" class="label">Ad Soyad</label>
            <div class="relative mt-1">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <User className="h-5 w-5 text-gray-400" />
              </div>
              <input
                id="full-name"
                name="full_name"
                type="text"
                required
                class="input pl-10"
                placeholder="Adınız Soyadınız"
              />
            </div>
          </div>
          
          <!-- Email -->
          <div>
            <label for="email" class="label">E-posta Adresi</label>
            <div class="relative mt-1">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <Mail className="h-5 w-5 text-gray-400" />
              </div>
              <input
                id="email"
                name="email"
                type="email"
                required
                class="input pl-10"
                placeholder="ornek@email.com"
              />
            </div>
          </div>
          
          <!-- Password -->
          <div>
            <label for="password" class="label">Şifre</label>
            <div class="relative mt-1">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <Lock className="h-5 w-5 text-gray-400" />
              </div>
              <input
                id="password"
                name="password"
                type="password"
                required
                minlength="8"
                class="input pl-10 pr-10"
                placeholder="••••••••"
              />
              <button
                type="button"
                id="toggle-password"
                class="absolute inset-y-0 right-0 pr-3 flex items-center"
              >
                <Eye id="eye-icon" className="h-5 w-5 text-gray-400" />
                <EyeOff id="eye-off-icon" className="h-5 w-5 text-gray-400 hidden" />
              </button>
            </div>
            <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">En az 8 karakter</p>
          </div>
          
          <!-- Confirm Password -->
          <div>
            <label for="confirm-password" class="label">Şifre Tekrar</label>
            <div class="relative mt-1">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <Lock className="h-5 w-5 text-gray-400" />
              </div>
              <input
                id="confirm-password"
                name="confirm_password"
                type="password"
                required
                class="input pl-10"
                placeholder="••••••••"
              />
            </div>
          </div>
        </div>
        
        <!-- Terms -->
        <div class="flex items-start">
          <div class="flex items-center h-5">
            <input
              id="terms"
              name="terms"
              type="checkbox"
              required
              class="h-4 w-4 text-urfa-600 focus:ring-urfa-500 border-gray-300 rounded"
            />
          </div>
          <div class="ml-3 text-sm">
            <label for="terms" class="text-gray-600 dark:text-gray-300">
              <a href="/kullanim-kosullari" class="text-urfa-600 hover:underline">Kullanım Koşulları</a>
              {' '}ve{' '}
              <a href="/gizlilik-politikasi" class="text-urfa-600 hover:underline">Gizlilik Politikası</a>
              {' '}nı okudum ve kabul ediyorum.
            </label>
          </div>
        </div>
        
        <!-- Submit Button -->
        <button type="submit" class="btn-primary w-full flex justify-center">
          Üye Ol
        </button>
      </form>
      
      <!-- Divider -->
      <div class="relative">
        <div class="absolute inset-0 flex items-center">
          <div class="w-full border-t border-gray-300"></div>
        </div>
        <div class="relative flex justify-center text-sm">
          <span class="px-2 bg-gray-50 dark:bg-gray-900 text-gray-500 dark:text-gray-400">veya</span>
        </div>
      </div>
      
      <!-- Social Register -->
      <div class="grid grid-cols-2 gap-3">
        <button
          type="button"
          class="flex items-center justify-center px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg shadow-sm text-sm font-medium text-gray-700 dark:text-gray-200 bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700"
        >
          <img class="h-5 w-5 mr-2" src="/icons/google.svg" alt="Google" />
          Google
        </button>
        <button
          type="button"
          class="flex items-center justify-center px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg shadow-sm text-sm font-medium text-gray-700 dark:text-gray-200 bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700"
        >
          <img class="h-5 w-5 mr-2" src="/icons/facebook.svg" alt="Facebook" />
          Facebook
        </button>
      </div>
      
      <!-- Benefits -->
      <div class="bg-urfa-50 dark:bg-urfa-900/20 rounded-xl p-4">
        <h3 class="font-medium text-urfa-900 dark:text-urfa-200 mb-2">Üyelik Avantajları:</h3>
        <ul class="space-y-1 text-sm text-urfa-700 dark:text-urfa-300">
          <li class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 bg-urfa-500 rounded-full"></span>
            Mekan yorumlayın ve puan verin
          </li>
          <li class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 bg-urfa-500 rounded-full"></span>
            Favorilerinizi kaydedin
          </li>
          <li class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 bg-urfa-500 rounded-full"></span>
            Puan kazanın ve rozetler toplayın
          </li>
          <li class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 bg-urfa-500 rounded-full"></span>
            Özel fırsatlardan haberdar olun
          </li>
        </ul>
      </div>
    </div>
  </div>
</Layout>

<script>
  // Toggle password visibility
  const togglePassword = document.getElementById('toggle-password');
  const passwordInput = document.getElementById('password');
  const eyeIcon = document.getElementById('eye-icon');
  const eyeOffIcon = document.getElementById('eye-off-icon');
  
  togglePassword?.addEventListener('click', () => {
    const type = passwordInput?.getAttribute('type') === 'password' ? 'text' : 'password';
    passwordInput?.setAttribute('type', type);
    eyeIcon?.classList.toggle('hidden');
    eyeOffIcon?.classList.toggle('hidden');
  });
  
  // Password match validation
  const form = document.querySelector('form');
  const confirmPassword = document.getElementById('confirm-password');
  
  form?.addEventListener('submit', (e) => {
    if (passwordInput?.value !== confirmPassword?.value) {
      e.preventDefault();
      alert('Şifreler eşleşmiyor.');
    }
  });
</script>
