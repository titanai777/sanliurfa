---
import Layout from '../../../layouts/Layout.astro';
import { User, Lock, Save, Shield } from 'lucide-react';
import { queryOne } from '../../../lib/postgres';

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect('/giris?redirect=/profil/ayarlar');
}

const profile = await queryOne('SELECT * FROM users WHERE id = $1', [user.id]);

const errorMessage = Astro.url.searchParams.get('error');
const successMessage = Astro.url.searchParams.get('success');

const errorMessages: Record<string, string> = {
  'update_failed': 'Profil güncellenirken bir hata oluştu.',
  'password_mismatch': 'Yeni şifreler eşleşmiyor.',
  'wrong_password': 'Mevcut şifre yanlış.',
};

const successMessages: Record<string, string> = {
  'profile_updated': 'Profil bilgileriniz başarıyla güncellendi.',
  'password_changed': 'Şifreniz başarıyla değiştirildi.',
};

const seo = {
  title: 'Ayarlar - Şanlıurfa.com',
  noindex: true
};
---

<Layout seo={seo}>
  <div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-8">
    <div class="container-custom max-w-3xl">
      <div class="flex items-center gap-4 mb-8">
        <a href="/profil" class="text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white">← Profil</a>
        <h1 class="text-2xl font-display font-bold text-gray-900 dark:text-white">Hesap Ayarları</h1>
      </div>
      
      {errorMessage && (
        <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 text-red-700 dark:text-red-400 px-4 py-3 rounded-lg mb-6">
          {errorMessages[errorMessage] || 'Bir hata oluştu.'}
        </div>
      )}
      
      {successMessage && (
        <div class="bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 text-green-700 dark:text-green-400 px-4 py-3 rounded-lg mb-6">
          {successMessages[successMessage] || 'İşlem başarılı.'}
        </div>
      )}
      
      <div class="space-y-6">
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4 flex items-center gap-2">
            <User className="w-5 h-5 text-urfa-600" />
            Profil Bilgileri
          </h2>
          
          <form action="/api/profile/update" method="POST" class="space-y-4">
            <div class="grid md:grid-cols-2 gap-4">
              <div>
                <label for="full_name" class="label dark:text-gray-300">Ad Soyad</label>
                <input type="text" id="full_name" name="full_name" value={profile?.full_name || ''} class="input dark:bg-gray-700 dark:border-gray-600 dark:text-white" />
              </div>
              <div>
                <label for="username" class="label dark:text-gray-300">Kullanıcı Adı</label>
                <input type="text" id="username" name="username" value={profile?.username || ''} class="input dark:bg-gray-700 dark:border-gray-600 dark:text-white" />
              </div>
            </div>
            
            <div>
              <label for="email" class="label dark:text-gray-300">E-posta</label>
              <input type="email" id="email" name="email" value={user.email} disabled class="input bg-gray-100 dark:bg-gray-700 dark:border-gray-600 dark:text-gray-400 cursor-not-allowed" />
            </div>
            
            <div>
              <label for="bio" class="label dark:text-gray-300">Hakkımda</label>
              <textarea id="bio" name="bio" rows="3" class="input dark:bg-gray-700 dark:border-gray-600 dark:text-white resize-none">{profile?.bio || ''}</textarea>
            </div>
            
            <div class="flex justify-end">
              <button type="submit" class="btn-primary flex items-center gap-2">
                <Save className="w-4 h-4" />
                Kaydet
              </button>
            </div>
          </form>
        </div>
        
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4 flex items-center gap-2">
            <Lock className="w-5 h-5 text-urfa-600" />
            Şifre Değiştir
          </h2>
          
          <form action="/api/profile/change-password" method="POST" class="space-y-4">
            <div>
              <label for="current_password" class="label dark:text-gray-300">Mevcut Şifre</label>
              <input type="password" id="current_password" name="current_password" required class="input dark:bg-gray-700 dark:border-gray-600 dark:text-white" />
            </div>
            
            <div class="grid md:grid-cols-2 gap-4">
              <div>
                <label for="new_password" class="label dark:text-gray-300">Yeni Şifre</label>
                <input type="password" id="new_password" name="new_password" required minlength="6" class="input dark:bg-gray-700 dark:border-gray-600 dark:text-white" />
              </div>
              <div>
                <label for="confirm_password" class="label dark:text-gray-300">Yeni Şifre (Tekrar)</label>
                <input type="password" id="confirm_password" name="confirm_password" required minlength="6" class="input dark:bg-gray-700 dark:border-gray-600 dark:text-white" />
              </div>
            </div>
            
            <div class="flex justify-end">
              <button type="submit" class="btn-secondary">Şifreyi Değiştir</button>
            </div>
          </form>
        </div>
        
        <div class="bg-red-50 dark:bg-red-900/20 rounded-xl border border-red-200 dark:border-red-800 p-6">
          <h2 class="text-lg font-semibold text-red-800 dark:text-red-400 mb-4 flex items-center gap-2">
            <Shield className="w-5 h-5" />
            Tehlikeli Bölge
          </h2>
          <p class="text-sm text-red-600 dark:text-red-400 mb-4">
            Hesabınızı sildiğinizde tüm verileriniz kalıcı olarak silinecektir.
          </p>
          <form action="/api/profile/delete" method="POST" onsubmit="return confirm('Hesabınızı silmek istediğinize emin misiniz?')">
            <button type="submit" class="text-red-600 hover:text-red-700 font-medium text-sm">Hesabımı Sil</button>
          </form>
        </div>
      </div>
    </div>
  </div>
</Layout>
