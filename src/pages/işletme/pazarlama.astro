---
import Layout from '../../layouts/Layout.astro';
import FeaturedListingsManager from '../../components/FeaturedListingsManager';
import MarketingCampaignBuilder from '../../components/MarketingCampaignBuilder';

// Check if user is authenticated
if (!Astro.locals.user) {
  return Astro.redirect('/giris');
}

const seo = {
  title: 'Pazarlama & Yeminli Listeler',
  description: 'İşletmenizi pazarlayın ve yeminli liste oluşturun',
  noindex: true
};
---

<Layout seo={seo}>
  <div class="bg-gray-50 dark:bg-gray-900 min-h-screen pt-20 pb-12">
    <div class="max-w-6xl mx-auto px-4">
      {/* Header */}
      <div class="mb-8">
        <h1 class="text-4xl font-bold text-gray-900 dark:text-white mb-2">
          Pazarlama & Yeminli Listeler
        </h1>
        <p class="text-gray-600 dark:text-gray-400">
          İşletmenizi pazarlayın, kampanyalar oluşturun ve yeminli listeler yönetin
        </p>
      </div>

      {/* Tabs */}
      <div class="grid md:grid-cols-2 gap-8">
        {/* Featured Listings */}
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
          <h2 class="text-2xl font-bold mb-6 pb-4 border-b border-gray-200 dark:border-gray-700">
            ✨ Yeminli Listeler
          </h2>
          <div class="text-sm text-gray-600 dark:text-gray-400 mb-6">
            <p>
              Yeminli listeler, işletmenizi platformda öne çıkarmak için premium bir özelliktir.
              Daha fazla görünürlük kazanın, müşteri trafiğini artırın ve başarıyı ölçün.
            </p>
          </div>
          <FeaturedListingsManager client:load />
        </div>

        {/* Marketing Campaigns */}
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
          <h2 class="text-2xl font-bold mb-6 pb-4 border-b border-gray-200 dark:border-gray-700">
            📊 Pazarlama Kampanyaları
          </h2>
          <div class="text-sm text-gray-600 dark:text-gray-400 mb-6">
            <p>
              Hedeflenen pazarlama kampanyaları oluşturun. Bütçe yönetimi, performans takibi
              ve detaylı analizler ile başarınızı maksimize edin.
            </p>
          </div>
          <MarketingCampaignBuilder client:load />
        </div>
      </div>

      {/* Info Cards */}
      <div class="grid md:grid-cols-3 gap-6 mt-8">
        <div class="bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg p-4">
          <h3 class="font-semibold text-blue-900 dark:text-blue-100 mb-2">📈 Analitik</h3>
          <p class="text-sm text-blue-800 dark:text-blue-200">
            Her kampanya ve yeminli listeninizin performansını gerçek zamanlı olarak izleyin.
          </p>
        </div>
        <div class="bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-lg p-4">
          <h3 class="font-semibold text-green-900 dark:text-green-100 mb-2">💰 Bütçe Kontrolü</h3>
          <p class="text-sm text-green-800 dark:text-green-200">
            Pazarlama harcamalarınızı kontrol edin ve ROI'nizi takip edin.
          </p>
        </div>
        <div class="bg-purple-50 dark:bg-purple-900/20 border border-purple-200 dark:border-purple-800 rounded-lg p-4">
          <h3 class="font-semibold text-purple-900 dark:text-purple-100 mb-2">🎯 Hedefleme</h3>
          <p class="text-sm text-purple-800 dark:text-purple-200">
            Kampanyalarınız için özel hedefler belirleyin ve doğru müşterilere ulaşın.
          </p>
        </div>
      </div>
    </div>
  </div>
</Layout>
