---
import Layout from '../../layouts/Layout.astro';
import { TransactionHistory } from '../../components/TransactionHistory';

// Redirect if not authenticated
if (!Astro.locals.user) {
  return Astro.redirect('/giris');
}
---

<Layout title="İşlem Geçmişi - Sadakat Programı">
  <div class="container mx-auto px-4 py-8">
    <div class="mb-8">
      <a href="/loyalty" class="text-blue-600 hover:underline mb-4 inline-block">← Geri Dön</a>
      <h1 class="text-4xl font-bold mb-2">İşlem Geçmişi</h1>
      <p class="text-gray-600">Tüm puan işlemlerinizi görüntüleyin</p>
    </div>

    <TransactionHistory client:load />
  </div>
</Layout>
