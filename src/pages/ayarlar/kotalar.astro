---
import Layout from '../../layouts/Layout.astro';
import QuotaUsageDisplay from '../../components/QuotaUsageDisplay';

// Require authentication
if (!Astro.locals.user) {
  return Astro.redirect('/giris');
}
---

<Layout title="Kullanım Kotaları - Şanlıurfa">
  <div class="max-w-4xl mx-auto px-4 py-8">
    <!-- Header -->
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">
        Kullanım Kotaları
      </h1>
      <p class="text-gray-600 dark:text-gray-400">
        Abonelik planınıza göre özellik kullanım limitlerini görüntüleyin
      </p>
    </div>

    <!-- Quota Display -->
    <QuotaUsageDisplay client:load />

    <!-- Info Section -->
    <div class="mt-12 grid md:grid-cols-2 gap-6">
      <div class="bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg p-6">
        <h3 class="text-lg font-semibold text-blue-900 dark:text-blue-300 mb-3">
          Kotalar Nasıl Çalışır?
        </h3>
        <ul class="space-y-2 text-sm text-blue-800 dark:text-blue-400">
          <li>✓ Her özelliğin abonelik seviyesine göre limiti vardır</li>
          <li>✓ Kotanız aylık olarak otomatik olarak sıfırlanır</li>
          <li>✓ Premium planlara yükseltin sınırsız erişim için</li>
          <li>✓ Kota uyarıları aldığınızda hemen yükseltin</li>
        </ul>
      </div>

      <div class="bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-lg p-6">
        <h3 class="text-lg font-semibold text-green-900 dark:text-green-300 mb-3">
          Plan Seçenekleri
        </h3>
        <p class="text-sm text-green-800 dark:text-green-400 mb-4">
          Kotalarınızı artırmak için plan yükseltin:
        </p>
        <a
          href="/fiyatlandirma"
          class="inline-block px-4 py-2 bg-green-600 hover:bg-green-700 text-white font-medium rounded-lg transition-colors"
        >
          Tüm Planları Gör →
        </a>
      </div>
    </div>

    <!-- FAQ -->
    <div class="mt-12">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">
        Sık Sorulan Sorular
      </h2>
      <div class="space-y-4">
        <div class="bg-white dark:bg-gray-800 rounded-lg p-6 border border-gray-200 dark:border-gray-700">
          <h4 class="font-semibold text-gray-900 dark:text-white mb-2">
            Kotam tükendiyse ne olur?
          </h4>
          <p class="text-gray-600 dark:text-gray-400">
            Kotanız tükenirse o özelliği kullanamazsınız. Aylık sıfırlanmasını bekleyebilir veya premium plana yükseltin.
          </p>
        </div>

        <div class="bg-white dark:bg-gray-800 rounded-lg p-6 border border-gray-200 dark:border-gray-700">
          <h4 class="font-semibold text-gray-900 dark:text-white mb-2">
            Kotalar ne zaman sıfırlanır?
          </h4>
          <p class="text-gray-600 dark:text-gray-400">
            Kotalar aylık olarak otomatik olarak sıfırlanır. Tam tarih yukarıdaki listeде gösterilmektedir.
          </p>
        </div>

        <div class="bg-white dark:bg-gray-800 rounded-lg p-6 border border-gray-200 dark:border-gray-700">
          <h4 class="font-semibold text-gray-900 dark:text-white mb-2">
            Sınırsız özellikler nelerdir?
          </h4>
          <p class="text-gray-600 dark:text-gray-400">
            Premium plana yükseltiğinizde çoğu özellik sınırsız hale gelir. Detaylar fiyatlandırma sayfasında bulunmaktadır.
          </p>
        </div>
      </div>
    </div>
  </div>
</Layout>
