---
import Layout from '../../layouts/Layout.astro';
import { MapPin, Clock, Camera, Search } from 'lucide-react';
import { query } from '../../lib/postgres';

const queryParam = Astro.url.searchParams.get('q') || '';

let sql = "SELECT * FROM historical_sites WHERE status = 'active'";
const values: any[] = [];

if (queryParam) {
  sql += " AND (name ILIKE $1 OR description ILIKE $1 OR location ILIKE $1)";
  values.push(`%${queryParam}%`);
}

sql += " ORDER BY is_featured DESC, created_at DESC";

const result = await query(sql, values);
const sites = result.rows;

const seo = {
  title: 'Tarihi Yerler - Şanlıurfa\'nın Zengin Tarihi',
  description: 'Göbeklitepe, Harran, Balıklıgöl ve daha fazlası. Şanlıurfa\'nın binlerce yıllık tarihi mirasını keşfedin.',
};
---

<Layout seo={seo}>
  <div class="page-header">
    <div class="page-header-content">
      <h1 class="page-header-title">Tarihi Yerler</h1>
      <p class="page-header-description">
        Tarihin sıfır noktası Şanlıurfa'nın eşsiz mirasını keşfedin.
      </p>
      
      <div class="mt-8 max-w-2xl mx-auto">
        <form action="/tarihi-yerler" class="relative">
          <input 
            type="search"
            name="q"
            value={queryParam}
            placeholder="Tarihi yer ara..."
            class="w-full pl-12 pr-4 py-4 rounded-xl bg-white/10 backdrop-blur-sm text-white placeholder-white/60 border border-white/20 focus:outline-none focus:border-white/40"
          />
          <Search className="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-white/60" />
        </form>
      </div>
    </div>
  </div>
  
  <div class="section bg-gray-50 dark:bg-gray-900">
    <div class="container-custom">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {sites.map((site) => (
          <article class="card-hover bg-white dark:bg-gray-800 rounded-2xl overflow-hidden group">
            <a href={`/tarihi-yerler/${site.slug}`}>
              <div class="relative aspect-[4/3] overflow-hidden">
                <img 
                  src={site.images?.[0] || '/images/placeholder-historical.jpg'}
                  alt={site.name}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                  loading="lazy"
                />
                {site.is_unesco && (
                  <div class="absolute top-4 left-4">
                    <span class="badge bg-blue-600 text-white">UNESCO</span>
                  </div>
                )}
                {site.is_featured && (
                  <div class="absolute top-4 right-4">
                    <span class="badge bg-urfa-600 text-white">Öne Çıkan</span>
                  </div>
                )}
              </div>
              
              <div class="p-6">
                <h3 class="font-display font-bold text-xl text-gray-900 dark:text-white group-hover:text-urfa-600 dark:group-hover:text-urfa-400 transition-colors">
                  {site.name}
                </h3>
                
                <div class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 mt-2">
                  <MapPin className="w-4 h-4" />
                  {site.location}
                </div>
                
                {site.period && (
                  <div class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 mt-1">
                    <Clock className="w-4 h-4" />
                    {site.period}
                  </div>
                )}
                
                <p class="text-gray-600 dark:text-gray-400 mt-3 line-clamp-2">
                  {site.short_description || site.description}
                </p>
                
                <div class="flex items-center gap-4 mt-4 text-sm text-urfa-600 dark:text-urfa-400 font-medium">
                  <span class="flex items-center gap-1">
                    <Camera className="w-4 h-4" />
                    {site.images?.length || 0} fotoğraf
                  </span>
                  <span>Detaylar →</span>
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>
      
      {sites.length === 0 && (
        <div class="text-center py-16">
          <Search className="w-16 h-16 text-gray-300 dark:text-gray-600 mx-auto mb-4" />
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-2">Sonuç bulunamadı</h3>
          <p class="text-gray-600 dark:text-gray-400">Farklı bir arama terimi deneyin.</p>
        </div>
      )}
    </div>
  </div>
</Layout>
