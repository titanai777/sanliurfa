---
import Layout from '../layouts/Layout.astro';
import { ContentManager } from '../components/ContentManager';

// Redirect if not logged in
if (!Astro.locals.user) {
  return Astro.redirect('/giris');
}
---

<Layout title="İçerik Yönetimi - Şanlıurfa">
  <div class="container mx-auto px-4 py-8">
    <div class="mb-8">
      <h1 class="text-4xl font-bold mb-2">İçerik Yönetimi</h1>
      <p class="text-gray-600">Şanlıurfa hakkında makale ve içerik oluşturun ve yayınlayın</p>
    </div>

    <ContentManager client:load />

    <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="bg-blue-50 rounded-lg p-6 border border-blue-200">
        <h3 class="font-semibold mb-2 text-blue-900">📝 Kolay Oluşturma</h3>
        <p class="text-sm text-gray-700">Basit editör ile profesyonel içerik oluşturun.</p>
      </div>

      <div class="bg-green-50 rounded-lg p-6 border border-green-200">
        <h3 class="font-semibold mb-2 text-green-900">🚀 Hızlı Yayınlama</h3>
        <p class="text-sm text-gray-700">Bir tıkla içeriğinizi yayınlayın ve paylaşın.</p>
      </div>

      <div class="bg-purple-50 rounded-lg p-6 border border-purple-200">
        <h3 class="font-semibold mb-2 text-purple-900">📊 Analitikler</h3>
        <p class="text-sm text-gray-700">İçeriğinizin performansını izleyin.</p>
      </div>
    </div>
  </div>
</Layout>
