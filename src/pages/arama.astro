---
import Layout from '../layouts/Layout.astro';
import { Search, MapPin, Star, Filter, X, FileText, Landmark, SlidersHorizontal } from 'lucide-react';
import Pagination from '../components/Pagination.astro';
import { query } from '../lib/postgres';

const queryParam = Astro.url.searchParams.get('q') || '';
const typeFilter = Astro.url.searchParams.get('type') || 'all';
const sortBy = Astro.url.searchParams.get('sort') || 'relevance';
const minRating = parseFloat(Astro.url.searchParams.get('minRating') || '0');
const priceRange = Astro.url.searchParams.get('price') || '';
const category = Astro.url.searchParams.get('category') || '';

const ITEMS_PER_PAGE = 12;
const currentPage = parseInt(Astro.url.searchParams.get('page') || '1');

let places: any[] = [];
let historicalSites: any[] = [];
let blogPosts: any[] = [];

if (queryParam || typeFilter !== 'all') {
  if (typeFilter === 'all' || typeFilter === 'place') {
    let sql = "SELECT * FROM places WHERE status = 'active'";
    const values: any[] = [];
    let paramIndex = 1;
    
    if (queryParam) {
      sql += ` AND (name ILIKE $${paramIndex} OR description ILIKE $${paramIndex} OR address ILIKE $${paramIndex})`;
      values.push(`%${queryParam}%`);
      paramIndex++;
    }
    
    if (minRating > 0) {
      sql += ` AND rating >= $${paramIndex}`;
      values.push(minRating);
      paramIndex++;
    }
    
    if (category && category !== 'all') {
      sql += ` AND category = $${paramIndex}`;
      values.push(category);
      paramIndex++;
    }
    
    sql += ` ORDER BY ${sortBy === 'rating' ? 'rating DESC' : sortBy === 'newest' ? 'created_at DESC' : 'rating DESC'} LIMIT $${paramIndex} OFFSET $${paramIndex + 1}`;
    values.push(ITEMS_PER_PAGE, (currentPage - 1) * ITEMS_PER_PAGE);
    
    const result = await query(sql, values);
    places = result.rows;
  }

  if (typeFilter === 'all' || typeFilter === 'historical') {
    let sql = "SELECT * FROM historical_sites WHERE status = 'active'";
    const values: any[] = [];
    
    if (queryParam) {
      sql += " AND (name ILIKE $1 OR description ILIKE $1 OR location ILIKE $1)";
      values.push(`%${queryParam}%`);
    }
    
    sql += " ORDER BY created_at DESC LIMIT $" + (values.length + 1);
    values.push(ITEMS_PER_PAGE);
    
    const result = await query(sql, values);
    historicalSites = result.rows;
  }

  if (typeFilter === 'all' || typeFilter === 'blog') {
    let sql = "SELECT * FROM blog_posts WHERE is_published = true";
    const values: any[] = [];
    
    if (queryParam) {
      sql += " AND (title ILIKE $1 OR excerpt ILIKE $1 OR content ILIKE $1)";
      values.push(`%${queryParam}%`);
    }
    
    if (category && category !== 'all') {
      sql += ` AND category = $${values.length + 1}`;
      values.push(category);
    }
    
    sql += " ORDER BY published_at DESC LIMIT $" + (values.length + 1);
    values.push(ITEMS_PER_PAGE);
    
    const result = await query(sql, values);
    blogPosts = result.rows;
  }
}

const countsResult = await query(
  `SELECT 
    (SELECT COUNT(*) FROM places WHERE status = 'active') as places_count,
    (SELECT COUNT(*) FROM historical_sites WHERE status = 'active') as sites_count,
    (SELECT COUNT(*) FROM blog_posts WHERE is_published = true) as blog_count`,
  []
);
const { places_count: totalPlaces, sites_count: totalSites, blog_count: totalBlog } = countsResult.rows[0];

const allResults = [
  ...places.map(p => ({ ...p, type: 'place', title: p.name })),
  ...historicalSites.map(s => ({ ...s, type: 'historical', title: s.name })),
  ...blogPosts.map(b => ({ ...b, type: 'blog', title: b.title })),
];

const categories = [
  { id: 'all', label: 'Tümü', count: allResults.length, icon: Search },
  { id: 'place', label: 'Mekanlar', count: places.length, icon: MapPin, total: totalPlaces },
  { id: 'historical', label: 'Tarihi Yerler', count: historicalSites.length, icon: Landmark, total: totalSites },
  { id: 'blog', label: 'Blog', count: blogPosts.length, icon: FileText, total: totalBlog },
];

const sortOptions = [
  { value: 'relevance', label: 'İlgili' },
  { value: 'rating', label: 'En Yüksek Puan' },
  { value: 'newest', label: 'En Yeni' },
  { value: 'name', label: 'İsim (A-Z)' },
];

const priceRanges = [
  { value: '', label: 'Tüm Fiyatlar' },
  { value: '1-1', label: '₺ (Ucuz)' },
  { value: '2-2', label: '₺₺ (Orta)' },
  { value: '3-3', label: '₺₺₺ (Pahalı)' },
  { value: '4-4', label: '₺₺₺₺ (Lüks)' },
];

const placeCategories = [
  { value: '', label: 'Tüm Kategoriler' },
  { value: 'restaurant', label: 'Restoran' },
  { value: 'cafe', label: 'Kafe' },
  { value: 'hotel', label: 'Otel' },
  { value: 'museum', label: 'Müze' },
  { value: 'park', label: 'Park' },
  { value: 'shopping', label: 'Alışveriş' },
  { value: 'entertainment', label: 'Eğlence' },
];

const popularSearches = ['Göbeklitepe', 'Balıklıgöl', 'Ciğer Kebabı', 'Harran', 'Çiğ Köfte', 'Hotel', 'Halfeti'];

const getResultLink = (result: any) => {
  switch (result.type) {
    case 'historical': return `/tarihi-yerler/${result.slug}`;
    case 'blog': return `/blog/${result.slug}`;
    default: return `/places/${result.slug}`;
  }
};

const getResultImage = (result: any) => {
  if (result.type === 'blog') return result.cover_image || '/images/placeholder-blog.jpg';
  return result.images?.[0] || '/images/placeholder-place.jpg';
};

const getResultCategory = (result: any) => {
  switch (result.type) {
    case 'historical': return 'Tarihi Yer';
    case 'blog': return result.category || 'Blog';
    default: return result.category || 'Mekan';
  }
};

const seo = {
  title: queryParam ? `"${queryParam}" Arama Sonuçları` : 'Ara',
  description: queryParam ? `"${queryParam}" için arama sonuçları` : 'Şanlıurfa\'da mekan, tarihi yer veya yemek ara',
};

const searchParams = new URLSearchParams();
if (queryParam) searchParams.set('q', queryParam);
if (typeFilter !== 'all') searchParams.set('type', typeFilter);
if (sortBy !== 'relevance') searchParams.set('sort', sortBy);
if (minRating > 0) searchParams.set('minRating', minRating.toString());
if (priceRange) searchParams.set('price', priceRange);
if (category) searchParams.set('category', category);
---

<Layout seo={seo}>
  <div class="min-h-screen bg-gray-50 dark:bg-gray-900">
    <div class="bg-white dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700 sticky top-0 z-10">
      <div class="container-custom py-4">
        <form action="/arama" class="relative max-w-2xl mx-auto">
          <input 
            type="search"
            name="q"
            value={queryParam}
            placeholder="Mekan, tarihi yer veya yemek ara..."
            class="w-full pl-12 pr-4 py-4 text-lg bg-gray-100 dark:bg-gray-700 dark:text-white rounded-xl border-0 focus:ring-2 focus:ring-urfa-500"
            autofocus
          />
          <Search className="absolute left-4 top-1/2 -translate-y-1/2 w-6 h-6 text-gray-400" />
          {queryParam && (
            <a href="/arama" class="absolute right-4 top-1/2 -translate-y-1/2 p-1 text-gray-400 dark:text-gray-500 hover:text-gray-600 dark:hover:text-gray-300">
              <X className="w-5 h-5" />
            </a>
          )}
        </form>
      </div>
    </div>
    
    <div class="container-custom py-8">
      {queryParam || typeFilter !== 'all' ? (
        <div class="grid lg:grid-cols-4 gap-8">
          <aside class="lg:col-span-1">
            <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-4 sticky top-24 space-y-6">
              <div>
                <h3 class="font-semibold text-gray-900 dark:text-white mb-3 flex items-center gap-2">
                  <Filter className="w-4 h-4" />
                  Kategori
                </h3>
                <nav class="space-y-1">
                  {categories.map(cat => (
                    <a 
                      href={`/arama?q=${encodeURIComponent(queryParam)}&type=${cat.id}${sortBy !== 'relevance' ? `&sort=${sortBy}` : ''}`}
                      class={`w-full flex items-center justify-between px-3 py-2 rounded-lg text-left transition-colors ${
                        typeFilter === cat.id 
                          ? 'bg-urfa-50 dark:bg-urfa-900/30 text-urfa-700 dark:text-urfa-300' 
                          : 'hover:bg-gray-50 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300'
                      }`}
                    >
                      <div class="flex items-center gap-2">
                        <cat.icon className="w-4 h-4" />
                        <span>{cat.label}</span>
                      </div>
                      <span class="text-sm text-gray-400 dark:text-gray-500">{cat.id === 'all' ? cat.count : cat.total}</span>
                    </a>
                  ))}
                </nav>
              </div>
              
              <div class="pt-4 border-t border-gray-100 dark:border-gray-700">
                <h3 class="font-semibold text-gray-900 dark:text-white mb-3">Sıralama</h3>
                <form id="sort-form">
                  <input type="hidden" name="q" value={queryParam} />
                  <input type="hidden" name="type" value={typeFilter} />
                  <select name="sort" class="w-full px-3 py-2 rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-700 text-gray-900 dark:text-white text-sm" onchange="this.form.submit()">
                    {sortOptions.map(opt => (
                      <option value={opt.value} selected={sortBy === opt.value}>{opt.label}</option>
                    ))}
                  </select>
                </form>
              </div>
              
              {(typeFilter === 'place' || typeFilter === 'all') && (
                <div class="pt-4 border-t border-gray-100 dark:border-gray-700">
                  <h3 class="font-semibold text-gray-900 dark:text-white mb-3 flex items-center gap-2">
                    <SlidersHorizontal className="w-4 h-4" />
                    Filtreler
                  </h3>
                  <form class="space-y-4">
                    <input type="hidden" name="q" value={queryParam} />
                    <input type="hidden" name="type" value={typeFilter} />
                    <input type="hidden" name="sort" value={sortBy} />
                    
                    <div>
                      <label class="block text-sm text-gray-600 dark:text-gray-400 mb-1">Mekan Türü</label>
                      <select name="category" class="w-full px-3 py-2 rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-700 text-gray-900 dark:text-white text-sm" onchange="this.form.submit()">
                        {placeCategories.map(opt => (
                          <option value={opt.value} selected={category === opt.value}>{opt.label}</option>
                        ))}
                      </select>
                    </div>
                    
                    <div>
                      <label class="block text-sm text-gray-600 dark:text-gray-400 mb-1">Minimum Puan</label>
                      <div class="flex gap-1">
                        {[1, 2, 3, 4].map(star => (
                          <a
                            href={`/arama?q=${encodeURIComponent(queryParam)}&type=${typeFilter}&sort=${sortBy}&minRating=${star}${category ? `&category=${category}` : ''}${priceRange ? `&price=${priceRange}` : ''}`}
                            class={`p-2 rounded-lg transition-colors ${minRating === star ? 'bg-yellow-100 text-yellow-600' : 'bg-gray-100 dark:bg-gray-700 text-gray-400 hover:bg-yellow-50'}`}
                          >
                            <Star className="w-4 h-4" />
                          </a>
                        ))}
                        {minRating > 0 && (
                          <a href={`/arama?q=${encodeURIComponent(queryParam)}&type=${typeFilter}&sort=${sortBy}${category ? `&category=${category}` : ''}${priceRange ? `&price=${priceRange}` : ''}`} class="p-2 rounded-lg text-red-500 hover:bg-red-50">
                            <X className="w-4 h-4" />
                          </a>
                        )}
                      </div>
                    </div>
                    
                    <div>
                      <label class="block text-sm text-gray-600 dark:text-gray-400 mb-1">Fiyat Aralığı</label>
                      <select name="price" class="w-full px-3 py-2 rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-700 text-gray-900 dark:text-white text-sm" onchange="this.form.submit()">
                        {priceRanges.map(opt => (
                          <option value={opt.value} selected={priceRange === opt.value}>{opt.label}</option>
                        ))}
                      </select>
                    </div>
                  </form>
                </div>
              )}
            </div>
          </aside>
          
          <main class="lg:col-span-3">
            <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-6">
              <h1 class="text-xl font-semibold text-gray-900 dark:text-white">
                {queryParam ? `"${queryParam}" için` : 'Toplam'} {allResults.length} sonuç
              </h1>
            </div>
            
            {allResults.length > 0 ? (
              <div class="space-y-4">
                {allResults.map(result => (
                  <a href={getResultLink(result)} class="flex gap-4 bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-4 hover:shadow-md transition-shadow group">
                    <div class="relative w-24 h-24 flex-shrink-0 overflow-hidden rounded-lg">
                      <img src={getResultImage(result)} alt={result.title} class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-110" loading="lazy" />
                    </div>
                    <div class="flex-1 min-w-0">
                      <h3 class="font-semibold text-gray-900 dark:text-white text-lg group-hover:text-urfa-600 dark:group-hover:text-urfa-400 transition-colors">{result.title}</h3>
                      {result.address && (
                        <p class="flex items-center gap-1 text-sm text-gray-600 dark:text-gray-400 mt-1">
                          <MapPin className="w-4 h-4 flex-shrink-0" />
                          <span class="truncate">{result.address || result.location}</span>
                        </p>
                      )}
                      {(result.excerpt || result.description) && (
                        <p class="text-sm text-gray-600 dark:text-gray-400 mt-1 line-clamp-2">{result.excerpt || result.description}</p>
                      )}
                    </div>
                  </a>
                ))}
              </div>
            ) : (
              <div class="text-center py-16 bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700">
                <Search className="w-16 h-16 text-gray-300 dark:text-gray-600 mx-auto mb-4" />
                <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-2">Sonuç bulunamadı</h3>
                <p class="text-gray-600 dark:text-gray-400 mb-4">Farklı anahtar kelimeler veya filtrelerle tekrar deneyin.</p>
                <a href={`/arama?q=${encodeURIComponent(queryParam)}`} class="btn-outline text-sm">Filtreleri Temizle</a>
              </div>
            )}
          </main>
        </div>
      ) : (
        <div class="max-w-2xl mx-auto text-center">
          <Search className="w-16 h-16 text-gray-300 mx-auto mb-6" />
          <h1 class="text-2xl font-display font-bold text-gray-900 dark:text-white mb-2">Ne aramıştınız?</h1>
          <p class="text-gray-600 dark:text-gray-400 mb-8">Mekanlar, tarihi yerler, yemekler ve daha fazlasını keşfedin.</p>
          
          <div class="text-left">
            <h3 class="text-sm font-medium text-gray-600 dark:text-gray-400 mb-3">Popüler Aramalar</h3>
            <div class="flex flex-wrap gap-2">
              {popularSearches.map(term => (
                <a href={`/arama?q=${encodeURIComponent(term)}`} class="px-4 py-2 bg-white dark:bg-gray-800 rounded-full border border-gray-200 dark:border-gray-700 text-gray-700 dark:text-gray-300 hover:border-urfa-500 hover:text-urfa-600 dark:hover:text-urfa-400 transition-colors">{term}</a>
              ))}
            </div>
          </div>
        </div>
      )}
    </div>
  </div>
</Layout>
