---
import Layout from '../layouts/Layout.astro';
import { AdvancedSearchPanel } from '../components/AdvancedSearchPanel';
---

<Layout title="Gelişmiş Arama - Şanlıurfa Rehberi">
  <div class="container mx-auto px-4 py-8">
    <div class="mb-8">
      <h1 class="text-4xl font-bold mb-2">Gelişmiş Arama</h1>
      <p class="text-gray-600">AI-destekli arama ile Şanlıurfa'da mükemmel mekanları bulun</p>
    </div>

    <AdvancedSearchPanel client:load />

    <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="bg-blue-50 rounded-lg p-6 border border-blue-200">
        <h3 class="font-semibold mb-2 text-blue-900">🤖 Yapay Zeka Destekli</h3>
        <p class="text-sm text-gray-700">Akıllı sıralama algoritması en alakalı sonuçları sunun.</p>
      </div>

      <div class="bg-green-50 rounded-lg p-6 border border-green-200">
        <h3 class="font-semibold mb-2 text-green-900">📊 Ki\u015fiselle\u015ftirilmi\u015f</h3>
        <p class="text-sm text-gray-700">Tercihlerinize göre özelleştirilmiş öneriler alın.</p>
      </div>

      <div class="bg-purple-50 rounded-lg p-6 border border-purple-200">
        <h3 class="font-semibold mb-2 text-purple-900">⚡ Anlık Öneriler</h3>
        <p class="text-sm text-gray-700">Yazarken gerçek zamanlı arama önerileri alın.</p>
      </div>
    </div>
  </div>
</Layout>
