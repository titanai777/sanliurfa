---
import Layout from '../../layouts/Layout.astro';
import ActivityFeed from '../../components/ActivityFeed';
import UserSuggestionsPanel from '../../components/UserSuggestionsPanel';
import HashtagExplorer from '../../components/HashtagExplorer';

// Auth check
const userId = Astro.locals.user?.id;
if (!userId) {
  return Astro.redirect('/giris?redirect=/sosyal');
}

// Get initial hashtag from URL params
const initialTag = Astro.url.searchParams.get('tag');
---

<Layout title="Sosyal - Şanlıurfa">
  <div class="container mx-auto px-4 py-8">
    <h1 class="text-4xl font-bold text-gray-900 mb-2">Sosyal</h1>
    <p class="text-gray-600 mb-8">Şanlıurfa sosyal akışı, trend konular ve kullanıcı önerileri</p>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      {/* Left Sidebar */}
      <div className="space-y-6">
        <div className="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
          <h2 className="text-lg font-semibold text-gray-900 dark:text-white mb-4">
            Sizi Tanıyabileceğiniz Kişiler
          </h2>
          <UserSuggestionsPanel client:load />
        </div>
      </div>

      {/* Main Content */}
      <div className="lg:col-span-2">
        {/* Tab Bar */}
        <div className="flex gap-4 border-b border-gray-200 dark:border-gray-700 mb-6">
          <button
            data-tab-btn="feed"
            class="px-4 py-2 font-semibold text-gray-900 dark:text-white border-b-2 border-blue-600"
          >
            Aktivite Akışı
          </button>
          <button
            data-tab-btn="hashtag"
            class="px-4 py-2 font-semibold text-gray-600 dark:text-gray-400 border-b-2 border-transparent hover:text-gray-900 dark:hover:text-white"
          >
            Hashtag Keşfet
          </button>
        </div>

        {/* Tab Content */}
        <div id="tab-feed" class="tab-content space-y-4">
          <ActivityFeed client:load userId={userId} />
        </div>

        <div id="tab-hashtag" class="tab-content hidden">
          <HashtagExplorer client:load initialSlug={initialTag} />
        </div>
      </div>
    </div>
  </div>

  <script>
    {
      // Tab switching logic
      const tabButtons = document.querySelectorAll('[data-tab-btn]');

      tabButtons.forEach(btn => {
        btn.addEventListener('click', () => {
          const tabName = btn.getAttribute('data-tab-btn');

          // Hide all tabs
          document.querySelectorAll('.tab-content').forEach(el => {
            el.classList.add('hidden');
          });

          // Remove active styles from all buttons
          tabButtons.forEach(b => {
            b.classList.remove('border-b-2', 'border-blue-600', 'text-gray-900', 'dark:text-white');
            b.classList.add('border-b-2', 'border-transparent', 'text-gray-600', 'dark:text-gray-400');
          });

          // Show selected tab
          const selectedTab = document.getElementById(`tab-${tabName}`);
          if (selectedTab) {
            selectedTab.classList.remove('hidden');
          }

          // Style selected button
          btn.classList.remove('border-b-2', 'border-transparent', 'text-gray-600', 'dark:text-gray-400');
          btn.classList.add('border-b-2', 'border-blue-600', 'text-gray-900', 'dark:text-white');
        });
      });

      // If hashtag tab is selected via initialTag, switch to it
      if (document.location.search.includes('tag=')) {
        const hashtagBtn = document.querySelector('[data-tab-btn="hashtag"]') as HTMLButtonElement;
        if (hashtagBtn) {
          hashtagBtn.click();
        }
      }
    }
  </script>
</Layout>
