---
import Layout from '../../layouts/Layout.astro';
import LoyaltyDashboard from '../../components/LoyaltyDashboard';

// Check if user is authenticated
if (!Astro.locals.user) {
  return Astro.redirect('/giris');
}

const seo = {
  title: 'Sadakat Programı',
  description: 'Puan kazanın ve özel ödüller açın',
  noindex: true
};
---

<Layout seo={seo}>
  <div class="bg-gray-50 dark:bg-gray-900 min-h-screen pt-20 pb-12">
    <div class="max-w-4xl mx-auto px-4">
      <LoyaltyDashboard client:load />

      {/* Info Section */}
      <div class="mt-12 grid md:grid-cols-3 gap-6">
        <div class="bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg p-6">
          <h3 class="font-semibold text-blue-900 dark:text-blue-100 mb-2">📝 Nasıl Kazanabilirsiniz?</h3>
          <ul class="text-sm text-blue-800 dark:text-blue-200 space-y-2">
            <li>✓ Yorum yazın: 10 puan</li>
            <li>✓ Fotoğraf ekleyin: 5 puan</li>
            <li>✓ Favori ekleyin: 2 puan</li>
            <li>✓ Etkinliğe katılın: 15 puan</li>
          </ul>
        </div>
        <div class="bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-lg p-6">
          <h3 class="font-semibold text-green-900 dark:text-green-100 mb-2">🎁 Ödülleri Nasıl Kullanabilirsiniz?</h3>
          <ul class="text-sm text-green-800 dark:text-green-200 space-y-2">
            <li>✓ İndirim kuponları</li>
            <li>✓ Özel rozetler</li>
            <li>✓ Premium özellikler</li>
            <li>✓ Hediye kartları</li>
          </ul>
        </div>
        <div class="bg-purple-50 dark:bg-purple-900/20 border border-purple-200 dark:border-purple-800 rounded-lg p-6">
          <h3 class="font-semibold text-purple-900 dark:text-purple-100 mb-2">⭐ Seviye Avantajları</h3>
          <ul class="text-sm text-purple-800 dark:text-purple-200 space-y-2">
            <li>✓ Bonus puan kazanç</li>
            <li>✓ Eksklusif ödüller</li>
            <li>✓ Frühe Zugang</li>
            <li>✓ VIP desteği</li>
          </ul>
        </div>
      </div>

      {/* FAQ Section */}
      <div class="mt-12 bg-white dark:bg-gray-800 rounded-lg shadow p-8">
        <h2 class="text-2xl font-bold mb-6">Sıkça Sorulan Sorular</h2>
        <div class="space-y-6">
          <div>
            <h3 class="font-semibold mb-2">Puanlarım ne zaman sona erer?</h3>
            <p class="text-gray-600 dark:text-gray-400">
              Puanlarınız asla sona ermez! Kazandığınız tüm puanlar hesabınızda saklanır.
            </p>
          </div>
          <div>
            <h3 class="font-semibold mb-2">Puanlarımı nasıl kullanabilirim?</h3>
            <p class="text-gray-600 dark:text-gray-400">
              Ödüller sayfasına giderek puanlarınızı harika ödüllere dönüştürebilirsiniz. Indirim kuponlarından premium özelliklere kadar birçok seçeneğiniz vardır.
            </p>
          </div>
          <div>
            <h3 class="font-semibold mb-2">Seviyemi nasıl yükseltebilirim?</h3>
            <p class="text-gray-600 dark:text-gray-400">
              Yalnızca puan kazanın! Belirli bir puan eşiğine ulaştığınızda otomatik olarak bir sonraki seviyeye yükseleceksiniz.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
