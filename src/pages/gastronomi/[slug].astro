---
import Layout from '../../layouts/Layout.astro';
import { Clock, Users, ChefHat, Flame, MapPin, Star, ArrowRight } from 'lucide-react';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { queryOne, queryRows } from '../../lib/postgres';

const { slug } = Astro.params;
const rawFood = await queryOne('SELECT * FROM foods WHERE slug = $1', [slug]);

if (!rawFood) {
  return Astro.redirect('/gastronomi');
}

const whereToEat = await queryRows(
  "SELECT id, name, slug, rating, address FROM places WHERE category = 'restaurant' AND status = 'active' ORDER BY rating DESC NULLS LAST LIMIT 3"
);

const coverImage =
  rawFood.cover_image ||
  (Array.isArray(rawFood.images) && rawFood.images.length > 0 ? rawFood.images[0] : '/images/placeholder-place.jpg');

const ingredients = Array.isArray(rawFood.ingredients) ? rawFood.ingredients : [];
const tags = Array.isArray(rawFood.tags) ? rawFood.tags : [];
const gallery = Array.isArray(rawFood.images) && rawFood.images.length > 0 ? rawFood.images : [coverImage];
const prepTime = rawFood.prep_time ? `${rawFood.prep_time} dk` : 'Belirtilmedi';

const food = {
  id: rawFood.id,
  slug: rawFood.slug,
  name: rawFood.name,
  description: rawFood.description || `${rawFood.name} Şanlıurfa mutfağının öne çıkan lezzetlerinden biridir.`,
  image: coverImage,
  gallery,
  history: rawFood.history || `${rawFood.name}, Şanlıurfa mutfağında uzun yıllardır bilinen yöresel tatlardan biridir.`,
  ingredients,
  preparation:
    ingredients.length > 0
      ? ingredients.map((ingredient: string, index: number) => `${index + 1}. ${ingredient}`).join('\n')
      : 'Tarif adımları yakında eklenecek.',
  isSpicy: Boolean(rawFood.is_spicy),
  isVegetarian: Boolean(rawFood.is_vegetarian),
  difficulty: rawFood.difficulty || 'Belirtilmedi',
  prepTime,
  servingSize: 'Belirtilmedi',
  calories: 'Belirtilmedi',
  rating: Number(rawFood.rating || 0),
  reviewCount: Number(rawFood.review_count || 0),
  whereToEat,
  tips:
    tags.length > 0
      ? tags.map((tag: string) => `${tag} bu lezzetin öne çıkan özelliklerinden biridir.`)
      : [
          'Geleneksel sunum için yöresel eşlikçilerle servis edin.',
          'Taze hazırlandığında en iyi sonucu verir.',
          'Yerel restoranlarda usta yorumlarını denemek en doğru karşılaştırmayı sağlar.'
        ],
};

const breadcrumbItems = [
  { label: 'Ana Sayfa', href: '/' },
  { label: 'Gastronomi', href: '/gastronomi' },
  { label: food.name, href: `/gastronomi/${food.slug}` },
];

const seo = {
  title: `${food.name} - Şanlıurfa'nın Efsane Lezzeti`,
  description: food.description,
  image: food.image,
  schema: {
    '@type': 'Recipe',
    name: food.name,
    description: food.description,
    image: food.image,
    recipeIngredient: food.ingredients,
    recipeInstructions: food.preparation,
    totalTime: 'PT45M',
    recipeYield: food.servingSize,
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: food.rating,
      reviewCount: food.reviewCount,
    },
  },
};
---

<Layout seo={seo}>
  <div class="min-h-screen bg-gray-50 dark:bg-gray-900">
    <!-- Breadcrumb -->
    <div class="bg-white dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700">
      <div class="container-custom py-4">
        <Breadcrumb items={breadcrumbItems} />
      </div>
    </div>
    
    <!-- Hero -->
    <div class="relative h-[400px] lg:h-[500px]">
      <img 
        src={food.image}
        alt={food.name}
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent" />
      
      <div class="absolute bottom-0 left-0 right-0">
        <div class="container-custom py-8">
          <div class="flex items-center gap-3 mb-4">
            {food.isSpicy && (
              <span class="inline-flex items-center gap-1 px-3 py-1 bg-isot-600 text-white text-sm rounded-full">
                <Flame className="w-4 h-4" />
                Acılı
              </span>
            )}
            <span class="inline-flex items-center gap-1 px-3 py-1 bg-white/20 text-white text-sm rounded-full backdrop-blur-sm">
              <ChefHat className="w-4 h-4" />
              {food.difficulty}
            </span>
          </div>
          <h1 class="text-4xl lg:text-6xl font-display font-bold text-white mb-2">
            {food.name}
          </h1>
          <p class="text-xl text-white/90 max-w-2xl">
            {food.description}
          </p>
        </div>
      </div>
    </div>
    
    <div class="container-custom py-8">
      <div class="grid lg:grid-cols-3 gap-8">
        <!-- Main Content -->
        <div class="lg:col-span-2 space-y-6">
          <!-- Quick Info -->
          <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
              <div class="text-center p-4 bg-gray-50 dark:bg-gray-700 rounded-xl">
                <Clock className="w-6 h-6 text-urfa-600 mx-auto mb-2" />
                <p class="text-sm text-gray-600 dark:text-gray-400">Hazırlama</p>
                <p class="font-semibold text-gray-900 dark:text-white">{food.prepTime}</p>
              </div>
              <div class="text-center p-4 bg-gray-50 dark:bg-gray-700 rounded-xl">
                <Users className="w-6 h-6 text-urfa-600 mx-auto mb-2" />
                <p class="text-sm text-gray-600 dark:text-gray-400">Porsiyon</p>
                <p class="font-semibold text-gray-900 dark:text-white">{food.servingSize}</p>
              </div>
              <div class="text-center p-4 bg-gray-50 dark:bg-gray-700 rounded-xl">
                <ChefHat className="w-6 h-6 text-urfa-600 mx-auto mb-2" />
                <p class="text-sm text-gray-600 dark:text-gray-400">Zorluk</p>
                <p class="font-semibold text-gray-900 dark:text-white">{food.difficulty}</p>
              </div>
              <div class="text-center p-4 bg-gray-50 dark:bg-gray-700 rounded-xl">
                <Star className="w-6 h-6 text-urfa-600 mx-auto mb-2" />
                <p class="text-sm text-gray-600 dark:text-gray-400">Puan</p>
                <p class="font-semibold text-gray-900 dark:text-white">{food.rating}/5</p>
              </div>
            </div>
          </div>
          
          <!-- History -->
          <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
            <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-4">Tarihçe</h2>
            <p class="text-gray-600 dark:text-gray-400 leading-relaxed">{food.history}</p>
          </div>
          
          <!-- Ingredients -->
          <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
            <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-4">Malzemeler</h2>
            <ul class="grid sm:grid-cols-2 gap-3">
              {food.ingredients.map(ingredient => (
                <li class="flex items-center gap-2 text-gray-700 dark:text-gray-300">
                  <span class="w-2 h-2 bg-urfa-500 rounded-full" />
                  {ingredient}
                </li>
              ))}
            </ul>
          </div>
          
          <!-- Preparation -->
          <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
            <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-4">Hazırlanışı</h2>
            <div class="prose dark:prose-invert max-w-none">
              <pre class="whitespace-pre-wrap font-sans text-gray-600 dark:text-gray-400">{food.preparation}</pre>
            </div>
          </div>
          
          <!-- Tips -->
          <div class="bg-urfa-50 dark:bg-urfa-900/20 rounded-xl p-6">
            <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-4">Püf Noktaları</h2>
            <ul class="space-y-3">
              {food.tips.map(tip => (
                <li class="flex items-start gap-3 text-gray-700 dark:text-gray-300">
                  <span class="w-6 h-6 bg-urfa-600 text-white rounded-full flex items-center justify-center text-sm flex-shrink-0">✓</span>
                  {tip}
                </li>
              ))}
            </ul>
          </div>
        </div>
        
        <!-- Sidebar -->
        <aside class="space-y-6">
          {/* Where to Eat */}
          <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
            <h3 class="font-semibold text-gray-900 dark:text-white mb-4">Nerede Yenir?</h3>
            <div class="space-y-3">
              {food.whereToEat.map(place => (
                <a href={`/places/${place.slug}`} class="flex items-center gap-3 p-3 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
                  <div class="w-12 h-12 bg-urfa-100 dark:bg-urfa-900/30 rounded-lg flex items-center justify-center text-urfa-600 dark:text-urfa-400 font-bold">
                    {place.name.charAt(0)}
                  </div>
                  <div class="flex-1">
                    <h4 class="font-medium text-gray-900 dark:text-white text-sm">{place.name}</h4>
                    <p class="text-xs text-gray-600 dark:text-gray-400">{place.address}</p>
                  </div>
                  <div class="flex items-center gap-1 text-sm">
                    <Star className="w-4 h-4 text-yellow-400 fill-current" />
                    <span class="font-medium">{place.rating}</span>
                  </div>
                </a>
              ))}
            </div>
            <a href="/places?category=restaurant" class="btn-outline w-full mt-4 text-sm flex items-center justify-center gap-2">
              Tüm Restoranlar
              <ArrowRight className="w-4 h-4" />
            </a>
          </div>
          
          {/* Nutrition Info */}
          <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
            <h3 class="font-semibold text-gray-900 dark:text-white mb-4">Besin Değerleri</h3>
            <div class="space-y-3">
              <div class="flex justify-between text-sm">
                <span class="text-gray-600 dark:text-gray-400">Kalori</span>
                <span class="font-medium text-gray-900 dark:text-white">{food.calories}</span>
              </div>
              <div class="flex justify-between text-sm">
                <span class="text-gray-600 dark:text-gray-400">Diyet</span>
                <span class="font-medium text-gray-900 dark:text-white">
                  {food.isVegetarian ? 'Vejetaryen' : 'Et Yemekleri'}
                </span>
              </div>
              <div class="flex justify-between text-sm">
                <span class="text-gray-600 dark:text-gray-400">Baharat</span>
                <span class="font-medium text-gray-900 dark:text-white">
                  {food.isSpicy ? 'Acılı' : 'Acısız'}
                </span>
              </div>
            </div>
          </div>
          
          {/* CTA */}
          <div class="bg-isot-600 rounded-xl p-6 text-white">
            <h3 class="font-semibold mb-2">Mekanınızı Ekleyin</h3>
            <p class="text-sm text-white/80 mb-4">
              Restoranınızı platformumuza ekleyerek binlerce kullanıcıya ulaşın.
            </p>
            <a href="/places/ekle" class="block w-full py-2 bg-white text-isot-600 rounded-lg font-medium text-center hover:bg-isot-50 transition-colors">
              Ücretsiz Kaydol
            </a>
          </div>
        </aside>
      </div>
    </div>
  </div>
</Layout>
