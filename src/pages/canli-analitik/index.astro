---
import Layout from '../../layouts/Layout.astro';
import LiveAnalyticsDashboard from '../../components/LiveAnalyticsDashboard';

// Admin-only access
const userId = Astro.locals.user?.id;
const isAdmin = Astro.locals.user?.role === 'admin';

if (!userId || !isAdmin) {
  return Astro.redirect('/giris');
}
---

<Layout title="Canlı Analitik | Şanlıurfa">
  <div class="container mx-auto px-4 py-8">
    <LiveAnalyticsDashboard client:load />
  </div>
</Layout>
