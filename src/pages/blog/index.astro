---
import Layout from '../../layouts/Layout.astro';
import { getBlogPosts, getBlogCategories } from '../../lib/blog';
import Pagination from '../../components/Pagination.astro';

const ITEMS_PER_PAGE = 12;
const currentPage = Math.max(1, parseInt(Astro.url.searchParams.get('page') || '1'));
const categorySlug = Astro.url.searchParams.get('category');

let categories: any[] = [];
let categoryId: number | undefined;
let selectedCategory: any = null;
let posts: any[] = [];
let total = 0;
let error = '';

try {
  // Kategorileri getir
  categories = await getBlogCategories();

  // Seçili kategoriyi bul
  if (categorySlug) {
    selectedCategory = categories.find(c => c.slug === categorySlug);
    categoryId = selectedCategory?.id;
  }

  // Blog yazılarını getir
  const offset = (currentPage - 1) * ITEMS_PER_PAGE;
  const result = await getBlogPosts({
    status: 'published',
    categoryId,
    limit: ITEMS_PER_PAGE,
    offset,
    sort: 'recent'
  });

  posts = result.posts;
  total = result.total;
} catch (err) {
  error = 'Blog yazıları yüklenirken hata oluştu';
  console.error('Blog listing error:', err);
}

const totalPages = Math.ceil(total / ITEMS_PER_PAGE);

// Featured post'u ilk sayfada göster
const showFeatured = currentPage === 1 && !categorySlug;
const featuredPost = showFeatured ? posts.find(p => p.isFeatured) : null;
const regularPosts = posts.filter(p => p.id !== featuredPost?.id);

const seo = {
  title: selectedCategory
    ? `${selectedCategory.name} - Blog | Şanlıurfa.com`
    : 'Blog | Şanlıurfa.com',
  description: selectedCategory?.description || 'Şanlıurfa hakkında makaleler, rehberler ve haberler',
};

const searchParams = new URLSearchParams();
if (categorySlug) searchParams.set('category', categorySlug);
---

<Layout seo={seo}>
  <div class="page-header">
    <div class="page-header-content">
      <h1 class="page-header-title">
        {selectedCategory ? selectedCategory.name : 'Blog'}
      </h1>
      <p class="page-header-description">
        {selectedCategory?.description || 'Şanlıurfa hakkında makaleler, rehberler ve haberler'}
      </p>
    </div>
  </div>

  {error && (
    <div class="section bg-red-50 dark:bg-red-900/20">
      <div class="container-custom">
        <p class="text-red-700 dark:text-red-300">{error}</p>
      </div>
    </div>
  )}
  
  <div class="section bg-gray-50 dark:bg-gray-900">
    <div class="container-custom">
      <div class="flex flex-col lg:flex-row gap-8">
        <aside class="lg:w-72 flex-shrink-0">
          <div class="sticky top-24 space-y-6">
            <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-4">
              <h3 class="font-semibold text-gray-900 dark:text-white mb-4">Kategoriler</h3>
              <div class="space-y-1">
                <a
                  href="/blog"
                  class={`flex items-center justify-between p-2 rounded-lg transition-colors ${
                    !categorySlug
                      ? 'bg-blue-50 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300'
                      : 'hover:bg-gray-50 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300'
                  }`}
                >
                  <span>Tümü</span>
                  <span class="text-sm text-gray-400">{total}</span>
                </a>
                {categories.map((cat) => (
                  <a
                    href={`/blog?category=${cat.slug}`}
                    class={`flex items-center justify-between p-2 rounded-lg transition-colors ${
                      categorySlug === cat.slug
                        ? 'bg-blue-50 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300'
                        : 'hover:bg-gray-50 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300'
                    }`}
                  >
                    <span>{cat.name}</span>
                    <span class="text-sm text-gray-400">{cat.postCount || 0}</span>
                  </a>
                ))}
              </div>
            </div>
            
            <div class="bg-urfa-600 rounded-xl p-6 text-white">
              <h3 class="font-semibold mb-2">Bültenimize Abone Olun</h3>
              <p class="text-sm text-urfa-100 mb-4">En yeni yazılardan ilk siz haberdar olun.</p>
              <form action="/api/newsletter/subscribe" method="POST" class="space-y-2">
                <input 
                  type="email"
                  name="email"
                  placeholder="E-posta adresiniz"
                  required
                  class="w-full px-3 py-2 rounded-lg bg-white/10 border border-white/20 text-white placeholder-white/60 focus:outline-none focus:border-white/40"
                />
                <button type="submit" class="w-full py-2 bg-white text-urfa-600 rounded-lg font-medium hover:bg-gray-100 transition-colors">
                  Abone Ol
                </button>
              </form>
            </div>
          </div>
        </aside>
        
        <main class="flex-1">
          {featuredPost && (
            <article class="card-hover bg-white dark:bg-gray-800 rounded-2xl overflow-hidden mb-8">
              <a href={`/blog/${featuredPost.slug}`} class="flex flex-col lg:flex-row">
                {featuredPost.featuredImage && (
                  <div class="lg:w-1/2 aspect-video lg:aspect-auto overflow-hidden">
                    <img
                      src={featuredPost.featuredImage}
                      alt={featuredPost.title}
                      class="w-full h-full object-cover transition-transform duration-500 hover:scale-105"
                      loading="eager"
                    />
                  </div>
                )}
                <div class={`${featuredPost.featuredImage ? 'lg:w-1/2' : 'lg:w-full'} p-6 lg:p-8 flex flex-col justify-center`}>
                  {featuredPost.categoryName && (
                    <span class="badge-primary w-fit mb-3">{featuredPost.categoryName}</span>
                  )}
                  <h2 class="text-2xl lg:text-3xl font-display font-bold text-gray-900 dark:text-white hover:text-blue-600 dark:hover:text-blue-400 transition-colors mb-3">
                    {featuredPost.title}
                  </h2>
                  <p class="text-gray-600 dark:text-gray-400 mb-4">{featuredPost.excerpt}</p>

                  <div class="flex items-center gap-4 text-sm text-gray-500 dark:text-gray-400">
                    {featuredPost.authorName && (
                      <div class="flex items-center gap-2">
                        <span>{featuredPost.authorName}</span>
                      </div>
                    )}
                    <div class="flex items-center gap-1">
                      📅 {new Date(featuredPost.publishedAt).toLocaleDateString('tr-TR', { day: 'numeric', month: 'long' })}
                    </div>
                    <div class="flex items-center gap-1">
                      ⏱️ {featuredPost.readTimeMinutes} dk
                    </div>
                  </div>
                </div>
              </a>
            </article>
          )}
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {regularPosts.map((post: any) => (
              <article class="card-hover bg-white dark:bg-gray-800 rounded-xl overflow-hidden group">
                <a href={`/blog/${post.slug}`}>
                  {post.featuredImage && (
                    <div class="relative aspect-video overflow-hidden">
                      <img
                        src={post.featuredImage}
                        alt={post.title}
                        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                        loading="lazy"
                      />
                      {post.categoryName && (
                        <div class="absolute top-3 left-3">
                          <span class="badge-primary">{post.categoryName}</span>
                        </div>
                      )}
                    </div>
                  )}
                  <div class="p-5">
                    <h3 class="font-display font-bold text-lg text-gray-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors line-clamp-2">
                      {post.title}
                    </h3>
                    <p class="text-gray-600 dark:text-gray-400 text-sm mt-2 line-clamp-2">{post.excerpt}</p>

                    <div class="flex items-center gap-4 mt-4 text-xs text-gray-500 dark:text-gray-400">
                      {post.authorName && (
                        <div class="flex items-center gap-1">
                          👤 {post.authorName}
                        </div>
                      )}
                      <div class="flex items-center gap-1">
                        📅 {new Date(post.publishedAt).toLocaleDateString('tr-TR', { day: 'numeric', month: 'long' })}
                      </div>
                    </div>
                  </div>
                </a>
              </article>
            ))}
          </div>
          
          {totalPages > 1 && (
            <Pagination
              currentPage={currentPage}
              totalPages={totalPages}
              baseUrl="/blog"
              searchParams={searchParams}
            />
          )}

          {regularPosts.length === 0 && !featuredPost && (
            <div class="text-center py-12 text-gray-500 dark:text-gray-400">
              {selectedCategory ? `${selectedCategory.name} kategorisinde henüz yazı bulunmuyor.` : 'Henüz blog yazısı bulunmuyor.'}
            </div>
          )}
        </main>
      </div>
    </div>
  </div>
</Layout>
