---
import Layout from '../../../layouts/Layout.astro';
import AdminLoyaltyPanel from '../../../components/AdminLoyaltyPanel';

// Admin guard
if (!Astro.locals.user || Astro.locals.user.role !== 'admin') {
  return Astro.redirect('/');
}
---

<Layout title="Sadakat Yönetimi | Admin">
  <div class="max-w-6xl mx-auto px-4 py-8">
    <div class="mb-6">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">Sadakat Yönetimi</h1>
      <p class="text-gray-600 dark:text-gray-400">Ödüller, puanlar ve rozetleri yönetin</p>
    </div>

    <AdminLoyaltyPanel client:load />
  </div>
</Layout>

<style>
  :global(body) {
    background-color: #f9fafb;
  }

  :global(.dark body) {
    background-color: #111827;
  }
</style>
