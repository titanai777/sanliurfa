---
import Layout from '../../layouts/Layout.astro';
import { query } from '../../lib/postgres';

const user = Astro.locals.user;

if (!user || !Astro.locals.isAdmin) {
  return Astro.redirect('/giris?redirect=/admin/users');
}

const result = await query('SELECT id, email, full_name, role, points, created_at, is_banned FROM users ORDER BY created_at DESC');
const users = result.rows;

const seo = { title: 'Kullanıcı Yönetimi - Admin' };
---

<Layout seo={seo}>
  <div class="min-h-screen bg-gray-100 dark:bg-gray-900 py-8">
    <div class="container-custom">
      <div class="flex items-center justify-between mb-8">
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Kullanıcılar</h1>
        <a href="/admin" class="text-urfa-600 hover:text-urfa-700">← Admin Panel</a>
      </div>
      
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm overflow-hidden">
        <table class="w-full">
          <thead class="bg-gray-50 dark:bg-gray-700">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Kullanıcı</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Rol</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Puan</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Kayıt Tarihi</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">İşlemler</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
            {users.map((u) => (
              <tr class={u.is_banned ? 'bg-red-50 dark:bg-red-900/10' : ''}>
                <td class="px-6 py-4">
                  <div class="text-sm font-medium text-gray-900 dark:text-white">{u.full_name || '-'}</div>
                  <div class="text-sm text-gray-500 dark:text-gray-400">{u.email}</div>
                </td>
                <td class="px-6 py-4">
                  <span class={`inline-flex px-2 py-1 text-xs rounded-full ${
                    u.role === 'admin' ? 'bg-red-100 text-red-800' : 'bg-gray-100 text-gray-800'
                  }`}>
                    {u.role}
                  </span>
                </td>
                <td class="px-6 py-4 text-sm text-gray-900 dark:text-white">{u.points || 0}</td>
                <td class="px-6 py-4 text-sm text-gray-500 dark:text-gray-400">
                  {new Date(u.created_at).toLocaleDateString('tr-TR')}
                </td>
                <td class="px-6 py-4">
                  {u.id !== user.id && (
                    <form method="POST" action={`/api/users/${u.id}/ban`} class="inline">
                      <input type="hidden" name="is_banned" value={u.is_banned ? 'false' : 'true'} />
                      <button type="submit" class={`text-sm ${u.is_banned ? 'text-green-600' : 'text-red-600'}`}>
                        {u.is_banned ? 'Aktifleştir' : 'Banla'}
                      </button>
                    </form>
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</Layout>
