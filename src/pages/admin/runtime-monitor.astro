---
import Layout from '../../layouts/Layout.astro';

const user = Astro.locals.user;

if (!user || !Astro.locals.isAdmin) {
  return Astro.redirect('/giris?redirect=/admin/runtime-monitor');
}

const seo = {
  title: 'Runtime Monitör - Şanlıurfa.com',
  description: 'Health, performance ve artifact health özetlerini tek ekranda izleyin.',
};
---

<Layout seo={seo}>
  <section class="min-h-screen bg-gray-100 dark:bg-gray-950 py-8">
    <div class="container-custom space-y-6">
      <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.24em] text-urfa-600">Runtime Monitör</p>
          <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Operasyon sinyalleri</h1>
          <p class="mt-2 max-w-3xl text-sm text-gray-600 dark:text-gray-400">
            Health, detailed health, performance ve artifact freshness özetleri aynı ekranda.
          </p>
        </div>
        <button
          id="refresh-runtime-monitor"
          class="inline-flex items-center justify-center rounded-xl bg-urfa-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-urfa-700"
          type="button"
        >
          Yenile
        </button>
      </div>

      <div id="runtime-monitor-status" class="rounded-2xl border border-gray-200 bg-white p-4 text-sm text-gray-600 shadow-sm dark:border-gray-800 dark:bg-gray-900 dark:text-gray-300">
        Veriler yükleniyor.
      </div>
      <div class="grid gap-4 md:grid-cols-3">
        <div class="rounded-2xl border border-gray-200 bg-white p-4 text-sm text-gray-600 shadow-sm dark:border-gray-800 dark:bg-gray-900 dark:text-gray-300">
          <div class="text-xs uppercase tracking-[0.18em] text-gray-500">Son yenileme</div>
          <div id="runtime-monitor-last-refresh" class="mt-2 text-lg font-semibold text-gray-900 dark:text-white">-</div>
        </div>
        <div class="rounded-2xl border border-gray-200 bg-white p-4 text-sm text-gray-600 shadow-sm dark:border-gray-800 dark:bg-gray-900 dark:text-gray-300">
          <div class="text-xs uppercase tracking-[0.18em] text-gray-500">Auto refresh</div>
          <div class="mt-2 text-lg font-semibold text-gray-900 dark:text-white">60 saniye</div>
        </div>
        <div class="rounded-2xl border border-gray-200 bg-white p-4 text-sm text-gray-600 shadow-sm dark:border-gray-800 dark:bg-gray-900 dark:text-gray-300">
          <div class="text-xs uppercase tracking-[0.18em] text-gray-500">Trend</div>
          <div id="runtime-monitor-trend" class="mt-2 text-sm font-semibold text-gray-900 dark:text-white">Henüz veri yok.</div>
        </div>
        <div class="rounded-2xl border border-gray-200 bg-white p-4 text-sm text-gray-600 shadow-sm dark:border-gray-800 dark:bg-gray-900 dark:text-gray-300">
          <div class="text-xs uppercase tracking-[0.18em] text-gray-500">Incident Delta</div>
          <div id="runtime-monitor-delta" class="mt-2 text-sm font-semibold text-gray-900 dark:text-white">Henüz veri yok.</div>
        </div>
      </div>

      <div class="grid gap-6 xl:grid-cols-2">
        <article class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-gray-900">
          <div class="flex items-center justify-between">
            <div>
              <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Root Health</h2>
              <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">`/api/health`</p>
            </div>
            <span id="health-badge" class="rounded-full bg-gray-100 px-3 py-1 text-xs font-semibold text-gray-700 dark:bg-gray-800 dark:text-gray-200">-</span>
          </div>
          <pre id="health-output" class="mt-4 overflow-x-auto rounded-xl bg-gray-950 p-4 text-xs text-green-200">Yükleniyor...</pre>
        </article>

        <article class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-gray-900">
          <div class="flex items-center justify-between">
            <div>
              <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Detailed Health</h2>
              <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">`/api/health/detailed`</p>
            </div>
            <span id="health-detailed-badge" class="rounded-full bg-gray-100 px-3 py-1 text-xs font-semibold text-gray-700 dark:bg-gray-800 dark:text-gray-200">-</span>
          </div>
          <pre id="health-detailed-output" class="mt-4 overflow-x-auto rounded-xl bg-gray-950 p-4 text-xs text-green-200">Yükleniyor...</pre>
        </article>

        <article class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-gray-900">
          <div class="flex items-center justify-between">
            <div>
              <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Performance</h2>
              <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">`/api/performance`</p>
            </div>
            <span id="performance-badge" class="rounded-full bg-gray-100 px-3 py-1 text-xs font-semibold text-gray-700 dark:bg-gray-800 dark:text-gray-200">-</span>
          </div>
          <pre id="performance-output" class="mt-4 overflow-x-auto rounded-xl bg-gray-950 p-4 text-xs text-green-200">Yükleniyor...</pre>
        </article>

        <article class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-gray-900">
          <div class="flex items-center justify-between">
            <div>
              <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Performance Optimization</h2>
              <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">`/api/admin/performance/optimization`</p>
            </div>
            <span id="optimization-badge" class="rounded-full bg-gray-100 px-3 py-1 text-xs font-semibold text-gray-700 dark:bg-gray-800 dark:text-gray-200">-</span>
          </div>
          <pre id="optimization-output" class="mt-4 overflow-x-auto rounded-xl bg-gray-950 p-4 text-xs text-green-200">Yükleniyor...</pre>
        </article>
      </div>
    </div>
  </section>

  <script type="module">
    import { initRuntimeMonitorPage } from '../../scripts/runtime-monitor-page.ts';

    initRuntimeMonitorPage();
  </script>
</Layout>
