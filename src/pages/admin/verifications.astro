---
/**
 * Admin Verification Management Page
 * Admin-only page for managing place verification requests
 */

import Layout from '../../layouts/Layout.astro';
import { AdminVerificationQueue } from '../../components/AdminVerificationQueue';

// Check admin access
const user = Astro.locals.user;
if (!user || user.role !== 'admin') {
  return Astro.redirect('/giris');
}

const seo = {
  title: 'Mekan Doğrulama Yönetimi - Admin',
  description: 'Mekan sahiplerinin doğrulama başvurularını inceleyin ve yönetin',
  noindex: true
};
---

<Layout seo={seo}>
  <div class="bg-gray-50 dark:bg-gray-900 min-h-screen pt-20">
    <div class="max-w-6xl mx-auto px-4 py-8">
      <div class="mb-8">
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">Mekan Doğrulama Yönetimi</h1>
        <p class="text-gray-600 dark:text-gray-400">Mekan sahiplerinin doğrulama başvurularını inceleyin ve yönetin.</p>
      </div>

      <AdminVerificationQueue client:load />
    </div>
  </div>
</Layout>
