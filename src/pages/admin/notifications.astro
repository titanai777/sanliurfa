---
/**
 * Admin - Push Notifications Yönetimi
 * Bildirimleri gönder, taslaklar, geçmiş
 */

// Auth kontrol
if (!Astro.locals.user?.isAdmin) {
  return Astro.redirect('/giris');
}

const pageTitle = 'Bildirimleri Yönet';
---

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{pageTitle} - Şanlıurfa.com</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/dompurify@3.0.6/dist/purify.min.js"></script>
</head>
<body class="bg-gray-50">
    <div class="min-h-screen p-6">
        <div class="max-w-6xl mx-auto">
            <!-- Header -->
            <div class="mb-8">
                <h1 class="text-3xl font-bold text-gray-900 mb-2">📢 Bildirimleri Yönet</h1>
                <p class="text-gray-600">Push bildirimleri gönder, taslakları yönet ve geçmişi görüntüle</p>
            </div>

            <!-- Tabs -->
            <div class="mb-6 flex gap-4 border-b border-gray-200">
                <button id="tab-send" class="px-4 py-2 font-medium text-blue-600 border-b-2 border-blue-600 cursor-pointer">
                    Gönder
                </button>
                <button id="tab-drafts" class="px-4 py-2 font-medium text-gray-600 cursor-pointer hover:text-blue-600">
                    Taslaklar
                </button>
                <button id="tab-history" class="px-4 py-2 font-medium text-gray-600 cursor-pointer hover:text-blue-600">
                    Geçmiş
                </button>
                <button id="tab-stats" class="px-4 py-2 font-medium text-gray-600 cursor-pointer hover:text-blue-600">
                    İstatistikler
                </button>
            </div>

            <!-- Send Tab -->
            <div id="content-send" class="grid grid-cols-3 gap-6">
                <!-- Form -->
                <div class="col-span-2">
                    <div class="bg-white rounded-lg shadow p-6">
                        <form id="notification-form" class="space-y-4">
                            <!-- Başlık -->
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-2">
                                    📝 Bildirim Başlığı
                                </label>
                                <input
                                    type="text"
                                    name="title"
                                    placeholder="örn: Yeni Blog Yazısı"
                                    required
                                    maxlength="100"
                                    class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                                />
                            </div>

                            <!-- Açıklama -->
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-2">
                                    📄 Açıklama
                                </label>
                                <textarea
                                    name="body"
                                    placeholder="Bildirim içeriğini yazın..."
                                    rows="4"
                                    maxlength="500"
                                    required
                                    class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                                ></textarea>
                            </div>

                            <!-- URL -->
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-2">
                                    🔗 Tıklanınca Gidecek URL
                                </label>
                                <input
                                    type="url"
                                    name="url"
                                    placeholder="/blog"
                                    class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                                />
                            </div>

                            <!-- Hedef Kitle -->
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-2">
                                    👥 Hedef Kitle
                                </label>
                                <select name="target" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
                                    <option value="all">Tüm Aboneler</option>
                                    <option value="blog">Blog Aboneleri</option>
                                    <option value="new">Yeni Kullanıcılar</option>
                                    <option value="active">Aktif Kullanıcılar</option>
                                </select>
                            </div>

                            <!-- Zamanla / Hemen Gönder -->
                            <div class="grid grid-cols-2 gap-4">
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-2">
                                        ⏰ Gönderme Zamanı
                                    </label>
                                    <input
                                        type="datetime-local"
                                        name="scheduled_for"
                                        class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                                    />
                                </div>
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-2">
                                        🎯 Öncelik
                                    </label>
                                    <select name="priority" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
                                        <option value="normal">Normal</option>
                                        <option value="high">Yüksek</option>
                                        <option value="urgent">Acil</option>
                                    </select>
                                </div>
                            </div>

                            <!-- Butonlar -->
                            <div class="flex gap-3 pt-4">
                                <button
                                    type="button"
                                    onclick="saveDraft()"
                                    class="flex-1 px-4 py-2 bg-gray-200 text-gray-800 rounded-lg font-medium hover:bg-gray-300 transition"
                                >
                                    💾 Taslak Olarak Kaydet
                                </button>
                                <button
                                    type="submit"
                                    class="flex-1 px-4 py-2 bg-blue-600 text-white rounded-lg font-medium hover:bg-blue-700 transition"
                                >
                                    ✈️ Gönder
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Preview -->
                <div>
                    <div class="bg-white rounded-lg shadow p-6">
                        <h3 class="font-semibold text-gray-900 mb-4">📱 Önizleme</h3>
                        <div class="bg-gradient-to-br from-blue-600 to-blue-700 rounded-lg p-4 text-white">
                            <p id="preview-title" class="font-bold text-lg mb-2">Bildirim Başlığı</p>
                            <p id="preview-body" class="text-sm text-blue-100 line-clamp-3">
                                Bildirim açıklaması burada gösterilir
                            </p>
                            <p class="text-xs text-blue-200 mt-3">şanlıurfa.com</p>
                        </div>
                        <div class="mt-4 space-y-2 text-sm text-gray-600">
                            <p><strong>Hedef:</strong> <span id="preview-target">Tüm Aboneler</span></p>
                            <p><strong>Zamanla:</strong> <span id="preview-time">Hemen</span></p>
                            <p><strong>Durum:</strong> <span class="text-yellow-600">Hazırlanıyor</span></p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Drafts Tab -->
            <div id="content-drafts" class="hidden">
                <div class="bg-white rounded-lg shadow">
                    <div class="p-6">
                        <h3 class="text-lg font-semibold text-gray-900 mb-4">Kaydedilmiş Taslaklar</h3>
                        <div id="drafts-list" class="space-y-3">
                            <p class="text-gray-500">Taslak yok</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- History Tab -->
            <div id="content-history" class="hidden">
                <div class="bg-white rounded-lg shadow">
                    <div class="p-6">
                        <h3 class="text-lg font-semibold text-gray-900 mb-4">Gönderilen Bildirimler</h3>
                        <div id="history-list" class="space-y-3">
                            <p class="text-gray-500">Geçmiş yükleniyor...</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Stats Tab -->
            <div id="content-stats" class="hidden">
                <div class="grid grid-cols-4 gap-4 mb-6">
                    <div class="bg-white rounded-lg shadow p-6">
                        <p class="text-gray-600 text-sm">📨 Toplam Gönderilen</p>
                        <p id="stat-total" class="text-2xl font-bold text-gray-900">0</p>
                    </div>
                    <div class="bg-white rounded-lg shadow p-6">
                        <p class="text-gray-600 text-sm">✅ Tıklanan</p>
                        <p id="stat-clicked" class="text-2xl font-bold text-green-600">0</p>
                    </div>
                    <div class="bg-white rounded-lg shadow p-6">
                        <p class="text-gray-600 text-sm">👥 Abone Sayısı</p>
                        <p id="stat-subscribers" class="text-2xl font-bold text-blue-600">0</p>
                    </div>
                    <div class="bg-white rounded-lg shadow p-6">
                        <p class="text-gray-600 text-sm">📈 Tıklama Oranı</p>
                        <p id="stat-rate" class="text-2xl font-bold text-purple-600">0%</p>
                    </div>
                </div>

                <div class="bg-white rounded-lg shadow p-6">
                    <h3 class="text-lg font-semibold text-gray-900 mb-4">Son Bildirimler</h3>
                    <div id="stats-detail" class="space-y-3">
                        <p class="text-gray-500">İstatistik yükleniyor...</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Tab yönetimi
        const tabs = {
            send: 'content-send',
            drafts: 'content-drafts',
            history: 'content-history',
            stats: 'content-stats'
        };

        Object.keys(tabs).forEach(tabName => {
            document.getElementById(`tab-${tabName}`).addEventListener('click', () => {
                // Tüm tab'ları gizle
                Object.values(tabs).forEach(contentId => {
                    document.getElementById(contentId).classList.add('hidden');
                });
                // Seçili tab'ı göster
                document.getElementById(tabs[tabName]).classList.remove('hidden');

                // Buton stilini güncelle
                Object.keys(tabs).forEach(name => {
                    const btn = document.getElementById(`tab-${name}`);
                    if (name === tabName) {
                        btn.classList.add('border-blue-600', 'text-blue-600');
                        btn.classList.remove('border-b', 'text-gray-600');
                    } else {
                        btn.classList.remove('border-blue-600', 'text-blue-600');
                        btn.classList.add('text-gray-600');
                    }
                });

                // İstatistikleri yükle
                if (tabName === 'stats') {
                    loadStats();
                }
                if (tabName === 'history') {
                    loadHistory();
                }
                if (tabName === 'drafts') {
                    loadDrafts();
                }
            });
        });

        // Form preview
        document.getElementById('notification-form').addEventListener('input', (e) => {
            const form = e.target.form;
            document.getElementById('preview-title').textContent = form.title.value || 'Bildirim Başlığı';
            document.getElementById('preview-body').textContent = form.body.value || 'Bildirim açıklaması burada gösterilir';
            document.getElementById('preview-target').textContent = form.target.value;
            document.getElementById('preview-time').textContent = form.scheduled_for.value ? 'Zamanlanmış' : 'Hemen';
        });

        // Taslak kaydet
        async function saveDraft() {
            const form = document.getElementById('notification-form');
            const data = new FormData(form);

            try {
                const response = await fetch('/api/notifications/draft', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(Object.fromEntries(data))
                });

                if (response.ok) {
                    alert('✓ Taslak kaydedildi');
                    form.reset();
                } else {
                    alert('✗ Hata oluştu');
                }
            } catch (error) {
                console.error('Hata:', error);
                alert('✗ Hata: ' + error.message);
            }
        }

        // Bildirim gönder
        document.getElementById('notification-form').addEventListener('submit', async (e) => {
            e.preventDefault();
            const form = e.target;
            const data = new FormData(form);

            try {
                const response = await fetch('/api/notifications/send', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(Object.fromEntries(data))
                });

                if (response.ok) {
                    alert('✓ Bildirim gönderildi');
                    form.reset();
                } else {
                    const error = await response.json();
                    alert('✗ Hata: ' + (error.error || 'Bildirim gönderilemedi'));
                }
            } catch (error) {
                console.error('Hata:', error);
                alert('✗ Hata: ' + error.message);
            }
        });

        // Güvenli innerHTML helper (DOMPurify ile)
        function safeSetHTML(element, html) {
            element.innerHTML = DOMPurify.sanitize(html);
        }

        // İstatistikleri yükle
        async function loadStats() {
            try {
                const response = await fetch('/api/notifications/stats');
                if (response.ok) {
                    const data = await response.json();
                    document.getElementById('stat-total').textContent = data.total || '0';
                    document.getElementById('stat-clicked').textContent = data.clicked || '0';
                    document.getElementById('stat-subscribers').textContent = data.subscribers || '0';
                    document.getElementById('stat-rate').textContent = (data.rate || 0).toFixed(1) + '%';
                }
            } catch (error) {
                console.error('İstatistik yükleme hatası:', error);
            }
        }

        // Geçmişi yükle
        async function loadHistory() {
            try {
                const response = await fetch('/api/notifications/history');
                const data = await response.json();
                const list = document.getElementById('history-list');
                if (data.notifications?.length) {
                    const html = data.notifications.map(n => `
                        <div class="border border-gray-200 rounded-lg p-4">
                            <p class="font-semibold text-gray-900">${DOMPurify.sanitize(n.title)}</p>
                            <p class="text-sm text-gray-600 mt-1">${DOMPurify.sanitize(n.body)}</p>
                            <p class="text-xs text-gray-500 mt-2">
                                📅 ${new Date(n.sent_at).toLocaleString('tr-TR')} •
                                👥 ${n.recipient_count} kişi •
                                ✅ ${n.click_count} tıkla
                            </p>
                        </div>
                    `).join('');
                    safeSetHTML(list, html);
                } else {
                    list.textContent = 'Gönderilen bildirim yok';
                }
            } catch (error) {
                console.error('Geçmiş yükleme hatası:', error);
            }
        }

        // Taslakları yükle
        async function loadDrafts() {
            try {
                const response = await fetch('/api/notifications/drafts');
                const data = await response.json();
                const list = document.getElementById('drafts-list');
                if (data.drafts?.length) {
                    const html = data.drafts.map(d => `
                        <div class="border border-gray-200 rounded-lg p-4">
                            <div class="flex justify-between items-start">
                                <div>
                                    <p class="font-semibold text-gray-900">${DOMPurify.sanitize(d.title)}</p>
                                    <p class="text-sm text-gray-600 mt-1">${DOMPurify.sanitize(d.body)}</p>
                                </div>
                                <button onclick="deleteDraft(${d.id})" class="text-red-600 hover:text-red-800">🗑️</button>
                            </div>
                        </div>
                    `).join('');
                    safeSetHTML(list, html);
                } else {
                    list.textContent = 'Taslak yok';
                }
            } catch (error) {
                console.error('Taslak yükleme hatası:', error);
            }
        }

        // Taslak sil
        async function deleteDraft(id) {
            if (confirm('Taslağı silmek istediğinize emin misiniz?')) {
                try {
                    await fetch(`/api/notifications/drafts/${id}`, { method: 'DELETE' });
                    loadDrafts();
                } catch (error) {
                    alert('Hata: ' + error.message);
                }
            }
        }
    </script>
</body>
</html>
