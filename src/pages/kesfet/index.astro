---
import Layout from "../../layouts/Layout.astro";
import TrendingPlaces from "../../components/TrendingPlaces";
import UserRecommendations from "../../components/UserRecommendations";

const { locals, redirect } = Astro;
if (!locals.user) {
  return redirect("/giris?redirect=/kesfet");
}
---

<Layout title="Kesfet - Sanliurfa.com">
  <div class="max-w-6xl mx-auto px-4 py-8">
    <div class="mb-12">
      <h1 class="text-4xl font-bold text-gray-900 dark:text-white mb-2">Kesfet</h1>
      <p class="text-gray-600 dark:text-gray-400">Yeni mekanlar ve kullanicilar bul</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <div class="lg:col-span-2">
        <div class="mb-12">
          <TrendingPlaces client:load />
        </div>
      </div>

      <div class="space-y-6">
        <div class="bg-white dark:bg-gray-800 p-6 rounded-lg border border-gray-200 dark:border-gray-700">
          <UserRecommendations client:load />
        </div>

        <div class="bg-blue-50 dark:bg-blue-900/20 p-6 rounded-lg border border-blue-200 dark:border-blue-800">
          <h3 class="font-bold text-gray-900 dark:text-white mb-4">Hizli Baglantilar</h3>
          <div class="space-y-2">
            <a href="/siralamalar" class="block text-sm text-blue-600 hover:text-blue-700">
              - Siralamalar
            </a>
            <a href="/arama" class="block text-sm text-blue-600 hover:text-blue-700">
              - Gelismis Arama
            </a>
            <a href="/bildirimler" class="block text-sm text-blue-600 hover:text-blue-700">
              - Bildirimler
            </a>
            <a href="/mesajlar" class="block text-sm text-blue-600 hover:text-blue-700">
              - Mesajlar
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
