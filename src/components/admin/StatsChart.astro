---
// Simple bar chart component for admin dashboard
interface DataPoint {
  label: string;
  value: number;
  color?: string;
}

interface Props {
  data: DataPoint[];
  title: string;
  maxValue?: number;
}

const { data, title, maxValue } = Astro.props;

const max = maxValue || Math.max(...data.map(d => d.value));
---

<div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
  <h3 class="font-semibold text-gray-900 dark:text-white mb-6">{title}</h3>
  
  <div class="space-y-3">
    {data.map(item => (
      <div>
        <div class="flex items-center justify-between mb-1">
          <span class="text-sm text-gray-600 dark:text-gray-400">{item.label}</span>
          <span class="text-sm font-medium text-gray-900 dark:text-white">{item.value}</span>
        </div>
        <div class="h-2 bg-gray-100 dark:bg-gray-700 rounded-full overflow-hidden">
          <div 
            class={`h-full rounded-full transition-all duration-500 ${item.color || 'bg-urfa-600'}`}
            style={`width: ${max > 0 ? (item.value / max) * 100 : 0}%`}
          ></div>
        </div>
      </div>
    ))}
  </div>
</div>
