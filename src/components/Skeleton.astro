---
interface Props {
  type?: 'card' | 'list' | 'text' | 'image' | 'avatar' | 'detail';
  count?: number;
  class?: string;
}

const { type = 'card', count = 1, class: className = '' } = Astro.props;
---

{Array.from({ length: count }).map((_, i) => (
  <div class:list={[
    'animate-pulse',
    type === 'card' && 'bg-white dark:bg-gray-800 rounded-xl p-4',
    type === 'list' && 'bg-white dark:bg-gray-800 rounded-lg p-4',
    className
  ]}>
    {type === 'card' && (
      <div class="space-y-4">
        <div class="aspect-video bg-gray-200 dark:bg-gray-700 rounded-lg"></div>
        <div class="h-4 bg-gray-200 dark:bg-gray-700 rounded w-3/4"></div>
        <div class="h-3 bg-gray-200 dark:bg-gray-700 rounded w-1/2"></div>
        <div class="flex gap-2">
          <div class="h-3 bg-gray-200 dark:bg-gray-700 rounded w-16"></div>
          <div class="h-3 bg-gray-200 dark:bg-gray-700 rounded w-16"></div>
        </div>
      </div>
    )}
    
    {type === 'list' && (
      <div class="flex gap-4">
        <div class="w-20 h-20 bg-gray-200 dark:bg-gray-700 rounded-lg flex-shrink-0"></div>
        <div class="flex-1 space-y-2">
          <div class="h-4 bg-gray-200 dark:bg-gray-700 rounded w-3/4"></div>
          <div class="h-3 bg-gray-200 dark:bg-gray-700 rounded w-1/2"></div>
          <div class="h-3 bg-gray-200 dark:bg-gray-700 rounded w-1/4"></div>
        </div>
      </div>
    )}
    
    {type === 'text' && (
      <div class="space-y-2">
        <div class="h-4 bg-gray-200 dark:bg-gray-700 rounded"></div>
        <div class="h-4 bg-gray-200 dark:bg-gray-700 rounded w-5/6"></div>
        <div class="h-4 bg-gray-200 dark:bg-gray-700 rounded w-4/6"></div>
      </div>
    )}
    
    {type === 'image' && (
      <div class="aspect-video bg-gray-200 dark:bg-gray-700 rounded-lg w-full"></div>
    )}
    
    {type === 'avatar' && (
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-gray-200 dark:bg-gray-700 rounded-full"></div>
        <div class="space-y-2">
          <div class="h-3 bg-gray-200 dark:bg-gray-700 rounded w-24"></div>
          <div class="h-2 bg-gray-200 dark:bg-gray-700 rounded w-16"></div>
        </div>
      </div>
    )}
    
    {type === 'detail' && (
      <div class="space-y-6">
        <div class="aspect-[21/9] bg-gray-200 dark:bg-gray-700 rounded-xl"></div>
        <div class="space-y-4">
          <div class="h-8 bg-gray-200 dark:bg-gray-700 rounded w-2/3"></div>
          <div class="h-4 bg-gray-200 dark:bg-gray-700 rounded w-1/3"></div>
        </div>
        <div class="grid grid-cols-3 gap-4">
          <div class="h-20 bg-gray-200 dark:bg-gray-700 rounded-lg"></div>
          <div class="h-20 bg-gray-200 dark:bg-gray-700 rounded-lg"></div>
          <div class="h-20 bg-gray-200 dark:bg-gray-700 rounded-lg"></div>
        </div>
        <div class="space-y-2">
          <div class="h-4 bg-gray-200 dark:bg-gray-700 rounded"></div>
          <div class="h-4 bg-gray-200 dark:bg-gray-700 rounded"></div>
          <div class="h-4 bg-gray-200 dark:bg-gray-700 rounded w-3/4"></div>
        </div>
      </div>
    )}
  </div>
))}

<style>
  @keyframes pulse {
    0%, 100% {
      opacity: 1;
    }
    50% {
      opacity: .5;
    }
  }
  
  .animate-pulse {
    animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }
</style>
