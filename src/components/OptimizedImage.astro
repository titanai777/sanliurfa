---
import { getImage } from 'astro:assets';

interface Props {
  src: string;
  alt: string;
  width?: number;
  height?: number;
  class?: string;
  loading?: 'eager' | 'lazy';
  fetchpriority?: 'high' | 'low' | 'auto';
  sizes?: string;
  format?: 'webp' | 'avif' | 'jpeg' | 'png';
  quality?: number;
  placeholder?: 'blur' | 'dominantColor' | 'none';
}

const {
  src,
  alt,
  width = 800,
  height,
  class: className = '',
  loading = 'lazy',
  fetchpriority = 'auto',
  sizes = '(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw',
  format = 'webp',
  quality = 80,
  placeholder = 'blur'
} = Astro.props;

// Generate srcset for responsive images
const widths = [320, 640, 960, 1280, 1920];
const srcset = widths
  .filter(w => w <= width)
  .map(w => `${src}?w=${w}&q=${quality}&fm=${format} ${w}w`)
  .join(', ');

// Calculate aspect ratio padding if height not provided
const aspectRatio = height ? undefined : '56.25%';
---

<div 
  class={`relative overflow-hidden ${className}`}
  style={aspectRatio ? `padding-top: ${aspectRatio}` : undefined}
>
  <img
    src={`${src}?w=${width}&q=${quality}&fm=${format}`}
    srcset={srcset}
    sizes={sizes}
    alt={alt}
    width={width}
    height={height}
    loading={loading}
    fetchpriority={fetchpriority}
    decoding="async"
    class={`absolute inset-0 w-full h-full object-cover transition-opacity duration-300 ${placeholder === 'blur' ? 'blur-sm' : ''}`}
    onload="this.classList.remove('blur-sm')"
  />
  
  {placeholder === 'blur' && (
    <div class="absolute inset-0 bg-gray-200 dark:bg-gray-700 animate-pulse -z-10" />
  )}
</div>

<style>
  img {
    opacity: 0;
  }
  img[src] {
    opacity: 1;
  }
</style>
