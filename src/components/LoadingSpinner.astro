---
interface Props {
  size?: 'sm' | 'md' | 'lg' | 'xl';
  color?: 'urfa' | 'white' | 'gray';
  class?: string;
}

const { size = 'md', color = 'urfa', class: className = '' } = Astro.props;

const sizeClasses = {
  sm: 'w-4 h-4 border-2',
  md: 'w-8 h-8 border-3',
  lg: 'w-12 h-12 border-4',
  xl: 'w-16 h-16 border-4'
};

const colorClasses = {
  urfa: 'border-urfa-600 border-t-transparent',
  white: 'border-white border-t-transparent',
  gray: 'border-gray-400 border-t-transparent'
};
---

<div 
  class={`inline-block rounded-full animate-spin ${sizeClasses[size]} ${colorClasses[color]} ${className}`}
  role="status"
  aria-label="Yükleniyor"
>
  <span class="sr-only">Yükleniyor...</span>
</div>
