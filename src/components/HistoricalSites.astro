---
import { Clock, MapPin, Ticket, Camera } from 'lucide-react';
import { query } from '../lib/postgres';

const result = await query(
  "SELECT * FROM historical_sites WHERE status = 'active' ORDER BY is_featured DESC, created_at DESC LIMIT 3"
);
const sites = result.rows;
---

<section class="section bg-gray-50 dark:bg-gray-900">
  <div class="container-custom">
    <div class="text-center max-w-3xl mx-auto mb-12">
      <span class="inline-flex items-center gap-2 text-urfa-600 font-medium mb-2">
        <Camera className="w-5 h-5" />
        Tarihi Miras
      </span>
      <h2 class="section-title dark:text-white">Tarihi Yerler</h2>
      <p class="section-subtitle dark:text-gray-400">
        12.000 yıllık tarihe tanıklık eden Şanlıurfa'nın en önemli tarihi ve kültürel mekanlarını keşfedin.
      </p>
    </div>
    
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      {sites?.map((site, index) => (
        <article class={`group relative ${index === 0 ? 'lg:col-span-2 lg:row-span-2' : ''}`}>
          <a href={`/tarihi-yerler/${site.slug}`} class="block h-full">
            <div class={`relative overflow-hidden rounded-2xl ${index === 0 ? 'h-full min-h-[500px]' : 'h-64'}`}>
              <img 
                src={site.images?.[0] || '/images/placeholder-historical.jpg'}
                alt={site.name}
                class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                loading="lazy"
              />
              
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent" />
              
              {site.is_unesco && (
                <div class="absolute top-4 left-4">
                  <span class="badge bg-blue-600 text-white">UNESCO Dünya Mirası</span>
                </div>
              )}
              
              {site.is_featured && !site.is_unesco && (
                <div class="absolute top-4 left-4">
                  <span class="badge bg-urfa-600 text-white">Öne Çıkan</span>
                </div>
              )}
              
              <div class="absolute bottom-0 left-0 right-0 p-6">
                <div class="flex items-center gap-2 text-white/80 text-sm mb-2">
                  <span class="px-2 py-0.5 bg-white/20 rounded text-xs">{site.period || 'Tarihi'}</span>
                </div>
                
                <h3 class={`font-display font-bold text-white mb-1 ${index === 0 ? 'text-3xl' : 'text-xl'}`}>
                  {site.name}
                </h3>
                
                <p class="text-white/90 font-medium mb-3">{site.short_description || site.location}</p>
                
                <div class={`grid gap-2 text-sm text-white/70 ${index === 0 ? 'grid-cols-3' : 'grid-cols-1'}`}>
                  <div class="flex items-center gap-2">
                    <Clock className="w-4 h-4" />
                    <span>{site.opening_hours || '08:00 - 18:00'}</span>
                  </div>
                  <div class="flex items-center gap-2">
                    <Ticket className="w-4 h-4" />
                    <span>{site.entry_fee || 'Ücretsiz'}</span>
                  </div>
                  <div class="flex items-center gap-2">
                    <MapPin className="w-4 h-4" />
                    <span class="truncate">{site.location}</span>
                  </div>
                </div>
              </div>
            </div>
          </a>
        </article>
      ))}
      
      {(!sites || sites.length === 0) && (
        <div class="col-span-full text-center py-12 text-gray-500 dark:text-gray-400">
          Henüz tarihi yer bulunmuyor.
        </div>
      )}
    </div>
    
    <div class="text-center mt-10">
      <a href="/tarihi-yerler" class="btn-primary inline-flex items-center gap-2">
        Tüm Tarihi Yerleri Gör
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
</section>
