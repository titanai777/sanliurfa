---
interface Props {
  user?: any;
}

const { user } = Astro.props;
---

{user && (
  <div id="push-notification-prompt" class="hidden fixed bottom-4 right-4 z-50 max-w-sm">
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-2xl border border-gray-200 dark:border-gray-700 p-4">
      <div class="flex items-start gap-3">
        <div class="w-10 h-10 bg-urfa-100 dark:bg-urfa-900/30 rounded-full flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5 text-urfa-600 dark:text-urfa-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
          </svg>
        </div>
        <div class="flex-1">
          <h3 class="font-semibold text-gray-900 dark:text-white">Bildirimlere İzin Ver</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">
            Yeni yorumlar, seviye atlama ve rozet bildirimlerini anında alın.
          </p>
          <div class="flex gap-2 mt-3">
            <button 
              id="enable-push"
              class="px-4 py-2 bg-urfa-600 text-white text-sm rounded-lg hover:bg-urfa-700 transition-colors"
            >
              İzin Ver
            </button>
            <button 
              id="dismiss-push"
              class="px-4 py-2 text-gray-600 dark:text-gray-400 text-sm hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg transition-colors"
            >
              Şimdi Değil
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
)}

<script>
  const prompt = document.getElementById('push-notification-prompt');
  const enableBtn = document.getElementById('enable-push');
  const dismissBtn = document.getElementById('dismiss-push');

  // Check if already subscribed or dismissed
  const hasPrompted = localStorage.getItem('push-prompt-dismissed');
  const isSubscribed = localStorage.getItem('push-subscribed');

  if (!hasPrompted && !isSubscribed && 'Notification' in window && 'serviceWorker' in navigator) {
    // Show prompt after 5 seconds
    setTimeout(() => {
      if (Notification.permission === 'default') {
        prompt?.classList.remove('hidden');
      }
    }, 5000);
  }

  enableBtn?.addEventListener('click', async () => {
    try {
      const permission = await Notification.requestPermission();
      
      if (permission === 'granted') {
        const registration = await navigator.serviceWorker.ready;
        
        // Subscribe to push notifications
        const subscription = await registration.pushManager.subscribe({
          userVisibleOnly: true,
          applicationServerKey: urlBase64ToUint8Array(
            import.meta.env.PUBLIC_VAPID_PUBLIC_KEY || ''
          ),
        });

        // Send subscription to server
        await fetch('/api/notifications/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(subscription),
        });

        localStorage.setItem('push-subscribed', 'true');
        prompt?.classList.add('hidden');
        
        if (window.toast) {
          window.toast.success('Bildirimler etkinleştirildi!');
        }
      }
    } catch (error) {
      console.error('Push subscription failed:', error);
    }
  });

  dismissBtn?.addEventListener('click', () => {
    localStorage.setItem('push-prompt-dismissed', 'true');
    prompt?.classList.add('hidden');
  });

  function urlBase64ToUint8Array(base64String: string): Uint8Array {
    const padding = '='.repeat((4 - (base64String.length % 4)) % 4);
    const base64 = (base64String + padding).replace(/-/g, '+').replace(/_/g, '/');
    const rawData = window.atob(base64);
    const outputArray = new Uint8Array(rawData.length);
    
    for (let i = 0; i < rawData.length; ++i) {
      outputArray[i] = rawData.charCodeAt(i);
    }
    
    return outputArray;
  }
</script>
