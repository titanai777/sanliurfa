---
import { Menu, X, User, Search, MapPin, ChevronDown, Sun, Moon } from 'lucide-react';
import NotificationCenter from './NotificationCenter.astro';
import NotificationBadge from './NotificationBadge';

interface Props {
  user?: any;
}

const { user } = Astro.props;

const navItems = [
  { 
    label: 'Keşfet', 
    href: '/kesfet',
    dropdown: [
      { label: 'Tarihi Yerler', href: '/tarihi-yerler', description: 'Göbeklitepe, Balıklıgöl ve daha fazlası' },
      { label: 'Mekanlar', href: '/places', description: 'Restoran, kafe, otel ve daha fazlası' },
      { label: 'Gastronomi', href: '/gastronomi', description: 'Urfa kebabı, çiğ köfte ve lezzetler' },
      { label: 'Etkinlikler', href: '/etkinlikler', description: 'Festivaller ve kültürel etkinlikler' },
    ]
  },
  { label: 'Blog', href: '/blog' },
  { label: 'Hakkında', href: '/hakkinda' },
  { label: 'İletişim', href: '/iletisim' },
];

const isCurrentPage = (href: string) => {
  const currentPath = Astro.url.pathname;
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
};
---

<header class="sticky top-0 z-50 bg-white/95 dark:bg-gray-900/95 backdrop-blur-md border-b border-gray-200 dark:border-gray-700">
  <div class="container-custom">
    <div class="flex items-center justify-between h-16 lg:h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center space-x-2 group">
        <div class="w-10 h-10 bg-urfa-600 rounded-lg flex items-center justify-center text-white font-bold text-xl group-hover:bg-urfa-700 transition-colors">
          Ş
        </div>
        <span class="hidden sm:block font-display font-bold text-xl text-gray-900 dark:text-white">
          Şanlıurfa<span class="text-urfa-600">.com</span>
        </span>
      </a>
      
      <!-- Desktop Navigation -->
      <nav class="hidden lg:flex items-center space-x-1">
        {navItems.map((item) => (
          <div class="relative group">
            <a 
              href={item.href}
              class={`nav-link flex items-center gap-1 px-3 py-2 rounded-lg transition-colors ${
                isCurrentPage(item.href) 
                  ? 'text-urfa-600 bg-urfa-50 dark:bg-urfa-900/20' 
                  : 'hover:bg-gray-50 dark:hover:bg-gray-800 dark:text-gray-200'
              }`}
            >
              {item.label}
              {item.dropdown && <ChevronDown className="w-4 h-4" />}
            </a>
            
            {item.dropdown && (
              <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
                <div class="bg-white dark:bg-gray-800 rounded-xl shadow-xl border border-gray-100 dark:border-gray-700 p-2 min-w-[280px]">
                  {item.dropdown.map((subItem) => (
                    <a 
                      href={subItem.href}
                      class="flex flex-col p-3 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors"
                    >
                      <span class="font-medium text-gray-900 dark:text-white">{subItem.label}</span>
                      <span class="text-sm text-gray-500 dark:text-gray-400">{subItem.description}</span>
                    </a>
                  ))}
                </div>
              </div>
            )}
          </div>
        ))}
      </nav>
      
      <!-- Right Side Actions -->
      <div class="flex items-center space-x-2">
        <!-- Search Button -->
        <!-- Theme Toggle (Mobile/Tablet) -->
        <button 
          id="theme-toggle-mobile"
          class="p-2 text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white hover:bg-gray-100 dark:hover:bg-gray-800 rounded-lg transition-colors lg:hidden"
          aria-label="Tema değiştir"
        >
          <Sun id="sun-icon-mobile" className="w-5 h-5 hidden dark:block" />
          <Moon id="moon-icon-mobile" className="w-5 h-5 block dark:hidden" />
        </button>
        
        <!-- Notifications Badge -->
        <NotificationBadge client:load />

        <!-- Notifications -->
        <NotificationCenter user={user} />
        
        <!-- Search Button -->
        <button 
          id="search-trigger"
          class="p-2 text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white hover:bg-gray-100 dark:hover:bg-gray-800 rounded-lg transition-colors"
          aria-label="Ara"
        >
          <Search className="w-5 h-5" />
        </button>
        
        <!-- Add Place Button (Desktop) -->
        <a 
          href="/places/ekle" 
          class="hidden md:flex items-center gap-1.5 btn-outline text-sm py-2"
        >
          <MapPin className="w-4 h-4" />
          <span>Mekan Ekle</span>
        </a>
        
        <!-- Auth Buttons -->
        {user ? (
          <div class="relative group">
            <button class="flex items-center gap-2 p-1 pr-3 rounded-full hover:bg-gray-100 transition-colors">
              <div class="w-8 h-8 bg-urfa-100 rounded-full flex items-center justify-center">
                <User className="w-4 h-4 text-urfa-600" />
              </div>
              <span class="hidden sm:block text-sm font-medium text-gray-700">{user.full_name?.split(' ')[0]}</span>
            </button>
            
            <div class="absolute right-0 top-full pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
              <div class="bg-white dark:bg-gray-800 rounded-xl shadow-xl border border-gray-100 dark:border-gray-700 p-2 min-w-[200px]">
                <a href="/profil" class="flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 text-sm dark:text-gray-200">
                  <User className="w-4 h-4" />
                  Profilim
                </a>
                <a href="/profil/favoriler" class="flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 text-sm dark:text-gray-200">
                  Favorilerim
                </a>
                <hr class="my-1 border-gray-100" />
                <form action="/api/auth/logout" method="POST">
                  <button type="submit" class="w-full flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-red-50 text-sm text-red-600 text-left">
                    Çıkış Yap
                  </button>
                </form>
              </div>
            </div>
          </div>
        ) : (
          <div class="hidden sm:flex items-center space-x-2">
            <a href="/giris" class="btn-secondary text-sm py-2">
              Giriş Yap
            </a>
            <a href="/kayit" class="btn-primary text-sm py-2">
              Üye Ol
            </a>
          </div>
        )}
        
        <!-- Mobile Menu Button -->
        <button 
          id="mobile-menu-trigger"
          class="lg:hidden p-2 text-gray-600 hover:text-gray-900 hover:bg-gray-100 rounded-lg transition-colors"
          aria-label="Menü"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <Menu id="menu-icon-open" className="w-6 h-6" />
          <X id="menu-icon-close" className="w-6 h-6 hidden" />
        </button>
      </div>
    </div>
  </div>
  
  <!-- Mobile Menu -->
  <div 
    id="mobile-menu" 
    class="lg:hidden fixed inset-0 top-16 bg-white dark:bg-gray-900 z-40 transform translate-x-full transition-transform duration-300 overflow-y-auto"
  >
    <div class="container-custom py-6 space-y-4">
      <!-- Mobile Search -->
      <form action="/arama" class="relative">
        <input 
          type="search"
          name="q"
          placeholder="Mekan, tarihi yer veya yemek ara..."
          class="input pr-10 dark:bg-gray-800 dark:border-gray-700 dark:text-white"
        />
        <button type="submit" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400">
          <Search className="w-5 h-5" />
        </button>
      </form>
      
      <!-- Mobile Nav Links -->
      <nav class="space-y-1">
        {navItems.map((item) => (
          <div>
            <a 
              href={item.href}
              class={`flex items-center justify-between px-4 py-3 rounded-lg font-medium ${
                isCurrentPage(item.href) 
                  ? 'bg-urfa-50 dark:bg-urfa-900/20 text-urfa-600' 
                  : 'text-gray-700 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-800'
              }`}
            >
              {item.label}
              {item.dropdown && <ChevronDown className="w-5 h-5" />}
            </a>
            
            {item.dropdown && (
              <div class="ml-4 mt-1 space-y-1 border-l-2 border-gray-100 dark:border-gray-700 pl-4">
                {item.dropdown.map((subItem) => (
                  <a 
                    href={subItem.href}
                    class="block px-4 py-2 text-sm text-gray-600 dark:text-gray-400 hover:text-urfa-600 dark:hover:text-urfa-400"
                  >
                    {subItem.label}
                  </a>
                ))}
              </div>
            )}
          </div>
        ))}
      </nav>
      
      <!-- Mobile Auth -->
      {!user && (
        <div class="grid grid-cols-2 gap-3 pt-4 border-t border-gray-200">
          <a href="/giris" class="btn-secondary text-center">
            Giriş Yap
          </a>
          <a href="/kayit" class="btn-primary text-center">
            Üye Ol
          </a>
        </div>
      )}
      
      <!-- Mobile Add Place -->
      <a 
        href="/places/ekle" 
        class="flex items-center justify-center gap-2 btn-accent w-full"
      >
        <MapPin className="w-5 h-5" />
        Mekan Ekle
      </a>
    </div>
  </div>
</header>

<!-- Search Modal -->
<div 
  id="search-modal" 
  class="fixed inset-0 z-50 bg-black/50 backdrop-blur-sm opacity-0 invisible transition-all duration-300"
>
  <div class="container-custom pt-20">
    <div class="bg-white rounded-2xl shadow-2xl max-w-2xl mx-auto overflow-hidden">
      <form action="/arama" class="relative">
        <input 
          type="search"
          name="q"
          placeholder="Mekan, tarihi yer veya yemek ara..."
          class="w-full px-6 py-5 text-lg border-0 focus:ring-0 placeholder-gray-400"
          autofocus
        />
        <button 
          type="submit" 
          class="absolute right-4 top-1/2 -translate-y-1/2 p-2 bg-urfa-600 text-white rounded-lg hover:bg-urfa-700 transition-colors"
        >
          <Search className="w-5 h-5" />
        </button>
      </form>
      
      <div class="border-t border-gray-100 dark:border-gray-700 px-6 py-4 bg-gray-50 dark:bg-gray-800">
        <p class="text-sm text-gray-500 mb-2">Popüler aramalar:</p>
        <div class="flex flex-wrap gap-2">
          {['Göbeklitepe', 'Balıklıgöl', 'Ciğer Kebabı', 'Harran', 'Urfa Kalesi'].map((term) => (
            <a 
              href={`/arama?q=${encodeURIComponent(term)}`}
              class="px-3 py-1 bg-white dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-full text-sm text-gray-600 dark:text-gray-300 hover:border-urfa-300 hover:text-urfa-600 dark:hover:text-urfa-400 transition-colors"
            >
              {term}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  // Mobile menu toggle
  const mobileMenuTrigger = document.getElementById('mobile-menu-trigger');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIconOpen = document.getElementById('menu-icon-open');
  const menuIconClose = document.getElementById('menu-icon-close');
  
  mobileMenuTrigger?.addEventListener('click', () => {
    const isExpanded = mobileMenuTrigger.getAttribute('aria-expanded') === 'true';
    mobileMenuTrigger.setAttribute('aria-expanded', String(!isExpanded));
    
    if (isExpanded) {
      mobileMenu?.classList.add('translate-x-full');
      menuIconOpen?.classList.remove('hidden');
      menuIconClose?.classList.add('hidden');
      document.body.style.overflow = '';
    } else {
      mobileMenu?.classList.remove('translate-x-full');
      menuIconOpen?.classList.add('hidden');
      menuIconClose?.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }
  });
  
  // Search modal
  const searchTrigger = document.getElementById('search-trigger');
  const searchModal = document.getElementById('search-modal');
  
  searchTrigger?.addEventListener('click', () => {
    searchModal?.classList.remove('opacity-0', 'invisible');
    searchModal?.querySelector('input')?.focus();
  });
  
  searchModal?.addEventListener('click', (e) => {
    if (e.target === searchModal) {
      searchModal?.classList.add('opacity-0', 'invisible');
    }
  });
  
  // Close search modal on escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      searchModal?.classList.add('opacity-0', 'invisible');
    }
  });
  
  // Mobile theme toggle
  const themeToggleMobile = document.getElementById('theme-toggle-mobile');
  const sunIconMobile = document.getElementById('sun-icon-mobile');
  const moonIconMobile = document.getElementById('moon-icon-mobile');
  
  function setMobileTheme(dark) {
    if (dark) {
      document.documentElement.classList.add('dark');
      sunIconMobile?.classList.remove('hidden');
      moonIconMobile?.classList.add('hidden');
    } else {
      document.documentElement.classList.remove('dark');
      sunIconMobile?.classList.add('hidden');
      moonIconMobile?.classList.remove('hidden');
    }
  }
  
  themeToggleMobile?.addEventListener('click', () => {
    const isDark = !document.documentElement.classList.contains('dark');
    setMobileTheme(isDark);
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
    // Sync with desktop toggle
    const event = new CustomEvent('themechange', { detail: { dark: isDark } });
    window.dispatchEvent(event);
  });
  
  // Initialize mobile theme
  const savedTheme = localStorage.getItem('theme');
  const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
  if (savedTheme === 'dark' || (!savedTheme && systemDark)) {
    setMobileTheme(true);
  }
</script>
