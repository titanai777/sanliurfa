---
import { Star, MapPin, Heart, TrendingUp } from 'lucide-react';
import { query } from '../lib/postgres';

const categories = [
  { id: 'all', label: 'Tümü' },
  { id: 'restaurant', label: 'Restoran' },
  { id: 'cafe', label: 'Kafe' },
  { id: 'hotel', label: 'Otel' },
  { id: 'museum', label: 'Müze' },
];

const result = await query(
  "SELECT * FROM places WHERE status = 'active' ORDER BY is_featured DESC, rating DESC LIMIT 8"
);
const places = result.rows;

const priceRangeSymbols = (range: number) => '₺'.repeat(range);

const getCategoryLabel = (category: string) => {
  const labels: Record<string, string> = {
    restaurant: 'Restoran', cafe: 'Kafe', hotel: 'Otel', museum: 'Müze',
    park: 'Park', shopping: 'Alışveriş', entertainment: 'Eğlence', other: 'Diğer',
  };
  return labels[category] || category;
};
---

<section id="featured" class="section bg-white dark:bg-gray-900">
  <div class="container-custom">
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-4 mb-10">
      <div>
        <span class="inline-flex items-center gap-2 text-isot-600 font-medium mb-2">
          <TrendingUp className="w-5 h-5" />
          Popüler Mekanlar
        </span>
        <h2 class="section-title dark:text-white">Öne Çıkan Mekanlar</h2>
        <p class="section-subtitle max-w-2xl dark:text-gray-400">
          Şanlıurfa'nın en çok ziyaret edilen ve en yüksek puan alan mekanlarını keşfedin.
        </p>
      </div>
      
      <div class="flex flex-wrap gap-2">
        {categories.map((cat) => (
          <button 
            class="px-4 py-2 rounded-full text-sm font-medium transition-colors bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-urfa-100 dark:hover:bg-urfa-900/30 hover:text-urfa-700 dark:hover:text-urfa-300 data-[active=true]:bg-urfa-600 data-[active=true]:text-white"
            data-category={cat.id}
            data-active={cat.id === 'all'}
          >
            {cat.label}
          </button>
        ))}
      </div>
    </div>
    
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {places?.map((place, index) => (
        <article 
          class="card-hover group"
          data-category={place.category}
          style={`animation-delay: ${index * 100}ms`}
        >
          <div class="relative aspect-[4/3] overflow-hidden rounded-t-xl">
            <img 
              src={place.images?.[0] || '/images/placeholder-place.jpg'}
              alt={place.name}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
              loading="lazy"
            />
            
            <div class="absolute top-3 left-3 flex flex-wrap gap-2">
              {place.is_featured && (
                <span class="badge-accent">Öne Çıkan</span>
              )}
              {place.is_verified && (
                <span class="badge bg-blue-600 text-white">Doğrulanmış</span>
              )}
            </div>
            
            <button 
              class="absolute top-3 right-3 w-8 h-8 bg-white/90 dark:bg-gray-800/90 hover:bg-white dark:hover:bg-gray-700 rounded-full flex items-center justify-center shadow-sm transition-colors"
              aria-label="Favorilere ekle"
            >
              <Heart className="w-4 h-4 text-gray-600 dark:text-gray-300" />
            </button>
            
            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity" />
          </div>
          
          <div class="p-4">
            <div class="flex items-start justify-between gap-2">
              <h3 class="font-semibold text-gray-900 dark:text-white group-hover:text-urfa-600 dark:group-hover:text-urfa-400 transition-colors">
                {place.name}
              </h3>
              <div class="flex items-center gap-1 text-sm">
                <Star className="w-4 h-4 text-yellow-400 fill-current" />
                <span class="font-medium">{place.rating || '4.5'}</span>
              </div>
            </div>
            
            <div class="flex items-center gap-1 text-sm text-gray-500 dark:text-gray-400 mt-1">
              <MapPin className="w-3.5 h-3.5" />
              {place.address}
            </div>
            
            <div class="flex flex-wrap gap-1 mt-3">
              <span class="px-2 py-0.5 bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-300 text-xs rounded-full">
                {getCategoryLabel(place.category)}
              </span>
              {place.tags?.slice(0, 1).map((tag: string) => (
                <span class="px-2 py-0.5 bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-300 text-xs rounded-full">
                  {tag}
                </span>
              ))}
            </div>
            
            <div class="flex items-center justify-between mt-4 pt-3 border-t border-gray-100 dark:border-gray-700">
              <span class="text-sm text-gray-500 dark:text-gray-400">
                {place.review_count || 0} değerlendirme
              </span>
              <span class="text-sm font-medium text-urfa-600">
                {priceRangeSymbols(place.price_range || 2)}
              </span>
            </div>
          </div>
        </article>
      ))}
      
      {(!places || places.length === 0) && (
        <div class="col-span-full text-center py-12 text-gray-500 dark:text-gray-400">
          Henüz mekan bulunmuyor.
        </div>
      )}
    </div>
    
    <div class="text-center mt-10">
      <a href="/places" class="btn-outline inline-flex items-center gap-2">
        Tüm Mekanları Gör
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
</section>

<script>
  const categoryButtons = document.querySelectorAll('[data-category]');
  const placeCards = document.querySelectorAll('article[data-category]');
  
  categoryButtons.forEach((button) => {
    button.addEventListener('click', () => {
      const selectedCategory = button.getAttribute('data-category');
      categoryButtons.forEach((btn) => btn.setAttribute('data-active', 'false'));
      button.setAttribute('data-active', 'true');
      
      placeCards.forEach((card) => {
        if (card instanceof HTMLElement) {
          const cardCategory = card.getAttribute('data-category');
          card.style.display = selectedCategory === 'all' || cardCategory === selectedCategory ? 'block' : 'none';
        }
      });
    });
  });
</script>
