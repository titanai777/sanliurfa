{
  "name": "sanliurfa",
  "version": "1.0.0",
  "description": "Şanlıurfa Şehir Rehberi - Tarihin Sıfır Noktası",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "dev:1111": "set PORT=1111 && astro dev",
    "dev:1112": "set PORT=1112 && astro dev",
    "dev:1113": "set PORT=1113 && astro dev",
    "dev:wsl": "source .env.wsl 2>/dev/null || true && astro dev --port 1111 --host",
    "build": "astro build",
    "build:1113": "set PORT=1113 && astro build",
    "preview": "astro preview",
    "preview:1111": "set PORT=1111 && astro preview",
    "preview:1112": "set PORT=1112 && astro preview",
    "preview:1113": "set PORT=1113 && astro preview",
    "start": "astro dev",
    "start:1111": "npm run dev:1111",
    "start:1112": "npm run dev:1112",
    "start:1113": "npm run dev:1113",
    "start:wsl": "npm run dev:wsl",
    "serve:1111": "npm run preview:1111",
    "serve:1112": "npm run preview:1112",
    "serve:1113": "npm run preview:1113",
    "astro": "astro",
    "format": "prettier --write . --plugin=prettier-plugin-astro",
    "lint": "astro check && tsc --noEmit",
    "lint:ci": "astro check --noSync && tsc --noEmit",
    "lint:phase": "tsc --noEmit -p tsconfig.phase.json",
    "test:unit": "vitest run",
    "test:phase:311-316": "vitest run src/lib/__tests__/governance-continuity-recovery-stability.test.ts",
    "test:phase:317-322": "vitest run src/lib/__tests__/governance-stability-recovery-confidence.test.ts",
    "test:phase:323-328": "vitest run src/lib/__tests__/governance-continuity-assurance-resilience.test.ts",
    "test:phase:329-334": "vitest run src/lib/__tests__/governance-trust-stability-continuity.test.ts",
    "test:phase:335-340": "vitest run src/lib/__tests__/governance-continuity-assurance-stability-cycle.test.ts",
    "test:phase:341-346": "vitest run src/lib/__tests__/governance-stability-confidence-assurance-continuity.test.ts",
    "test:phase:347-352": "vitest run src/lib/__tests__/governance-assurance-stability-trust-continuity.test.ts",
    "test:phase:353-358": "vitest run src/lib/__tests__/governance-continuity-stability-trust-resilience-v3.test.ts",
    "test:phase:359-364": "vitest run src/lib/__tests__/governance-trust-continuity-suite-v3.test.ts",
    "test:phase:365-370": "vitest run src/lib/__tests__/governance-recovery-assurance-suite-v4.test.ts",
    "test:phase:371-376": "vitest run src/lib/__tests__/governance-assurance-continuity-suite-v5.test.ts",
    "test:phase:377-382": "vitest run src/lib/__tests__/governance-continuity-assurance-suite-v6.test.ts",
    "test:phase:383-388": "vitest run src/lib/__tests__/governance-stability-assurance-suite-v7.test.ts",
    "test:phase:389-394": "vitest run src/lib/__tests__/governance-assurance-recovery-suite-v8.test.ts",
    "test:phase:prev": "npm run test:phase:383-388",
    "test:phase:latest": "npm run test:phase:389-394",
    "test:phase:smoke": "npm run test:phase:prev && npm run test:phase:latest",
    "test:phase:gate": "npm run lint:phase && npm run test:phase:smoke && npm run build",
    "test:phase:gate:ci": "npm run lint:phase && npm run test:phase:smoke && npm run build",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test": "npm run test:unit && npm run test:e2e",
    "lighthouse": "lhci autorun",
    "lighthouse:local": "npm run build && lhci autorun",
    "wsl:setup": "./scripts/wsl-setup.sh",
    "wsl:start": "./scripts/wsl-start.sh",
    "wsl:stop": "./scripts/wsl-stop.sh",
    "wsl:reset": "./scripts/wsl-reset.sh",
    "db:start": "docker-compose -f docker-compose.dev.yml up -d",
    "db:stop": "docker-compose -f docker-compose.dev.yml down",
    "db:reset": "docker-compose -f docker-compose.dev.yml down -v && docker-compose -f docker-compose.dev.yml up -d",
    "db:logs": "docker-compose -f docker-compose.dev.yml logs -f",
    "db:psql": "docker exec -it sanliurfa-postgres psql -U postgres -d sanliurfa",
    "migrate": "tsx scripts/migrate.ts",
    "migrate:status": "tsx scripts/migrate.ts status",
    "migrate:rollback": "tsx scripts/migrate.ts rollback",
    "admin": "tsx scripts/admin-cli.ts",
    "backup": "./scripts/backup.sh",
    "deploy": "./scripts/deploy.sh",
    "analyze": "node scripts/analyze-bundle.js",
    "check": "node scripts/final-check.js"
  },
  "keywords": [
    "sanliurfa",
    "şehir rehberi",
    "göbeklitepe",
    "turizm",
    "astro"
  ],
  "author": "Sanliurfa.com",
  "license": "MIT",
  "dependencies": {
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/node": "^10.0.4",
    "@astrojs/partytown": "^2.1.4",
    "@astrojs/react": "^4.2.1",
    "@astrojs/rss": "^4.0.11",
    "@astrojs/sitemap": "^3.2.1",
    "@astrojs/tailwind": "^6.0.0",
    "@supabase/supabase-js": "^2.49.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/pg": "^8.20.0",
    "astro": "^6.1.3",
    "astro-compress": "^2.3.6",
    "bcryptjs": "^3.0.3",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.487.0",
    "pg": "^8.20.0",
    "rate-limiter-flexible": "^11.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "redis": "^4.7.0",
    "resend": "^6.10.0",
    "stripe": "^22.0.0",
    "swagger-ui-dist": "^5.32.1",
    "web-push": "^3.6.7",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.16",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.21",
    "jsdom": "^29.0.1",
    "lighthouse": "^12.8.2",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "prettier-plugin-astro": "^0.14.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.7.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
