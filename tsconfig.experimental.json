{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "verbatimModuleSyntax": false,
    "isolatedModules": false,
    "types": ["node", "astro/client"]
  },
  "include": [
    "src/lib/**/*.ts",
    "src/env.d.ts"
  ],
  "exclude": [
    "src/lib/ai-analytics.ts",
    "src/lib/apm.ts",
    "src/lib/data-transformation.ts",
    "src/lib/feature-gating.ts",
    "src/lib/financial-analytics.ts",
    "src/lib/financial-planning.ts",
    "src/lib/init-migrations.ts",
    "src/lib/pwa.ts",
    "src/lib/rag-system.ts",
    "src/lib/reputation.ts",
    "src/lib/risk-management.ts",
    "src/lib/__tests__/**",
    "src/**/*.test.ts",
    "src/**/*.spec.ts"
  ]
}
