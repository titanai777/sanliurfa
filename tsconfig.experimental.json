{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "verbatimModuleSyntax": false,
    "isolatedModules": false,
    "types": ["node", "astro/client"]
  },
  "include": [
    "src/lib/**/*.ts",
    "src/env.d.ts"
  ],
  "exclude": [
    "src/lib/index.ts",
    "src/lib/__tests__/**",
    "src/**/*.test.ts",
    "src/**/*.spec.ts"
  ]
}
