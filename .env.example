# ====== CRITICAL VARIABLES (Required) ======
NODE_ENV=production
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/sanliurfa
READ_REPLICA_URL=
JWT_SECRET=your-secret-key-min-32-characters-long!
REDIS_URL=redis://127.0.0.1:6379

# ====== APP CONFIG ======
PORT=1111
PUBLIC_SITE_URL=http://127.0.0.1:1111
CORS_ORIGINS=https://sanliurfa.com
REDIS_KEY_PREFIX=sanliurfa:

# ====== DATABASE ======
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=sanliurfa
DB_USER=postgres
DB_PASSWORD=postgres

# ====== STRIPE (Payment) ======
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ====== EMAIL (Resend) ======
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@sanliurfa.com

# ====== PUSH NOTIFICATIONS ======
VAPID_PUBLIC_KEY=...
VAPID_PRIVATE_KEY=...

# ====== SENTRY (Error Logging) ======
SENTRY_DSN=https://...@sentry.io/...

# ====== THIRD-PARTY INTEGRATIONS ======
SUPABASE_URL=https://...supabase.co
SUPABASE_ANON_KEY=...

# ====== MONITORING & ANALYTICS ======
GOOGLE_ANALYTICS_ID=G-...

# ====== FEATURE FLAGS ======
FEATURE_FLAGS_ENABLED=true

# ====== STAGING ENVIRONMENT ======
STAGING_URL=https://staging.sanliurfa.com
STAGING_DATABASE_URL=postgresql://user:password@staging-db:5432/sanliurfa
STAGING_REDIS_URL=redis://staging-redis:6379

# ====== LOGGING ======
LOG_LEVEL=info

# ====== CACHE ======
CACHE_TTL=600

# ====== RATE LIMITING ======
RATE_LIMIT_WINDOW=900
RATE_LIMIT_MAX=100

# ====== SESSION ======
SESSION_TTL=86400
SESSION_SECRET=session-secret-key-min-32-characters!

# ====== AWS (Optional - for S3 uploads) ======
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=eu-central-1
S3_BUCKET=sanliurfa-uploads
